/* Vant Weapp 样式已通过 usingComponents 自动引入 */

page {
  background: #f7f8fa;
  color: #323233;
  font-size: 28rpx;
  --van-button-primary-color: #1677ff;
  --van-primary-color: #1677ff;
  --van-success-color: #07c160;
  --van-warning-color: #f5a623;
  --van-danger-color: #ff4d4f;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Card */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.sub {
  color: #969799;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* Button */
.btn-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.btn {
  background: #1677ff;
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn.secondary {
  background: #f7f8fa;
  color: #323233;
  border: 2rpx solid #ebedf0;
}

/* Placeholder */
.placeholder {
  color: #c8c9cc;
  font-size: 24rpx;
}

/* Flex utilities */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* Text */
.text-primary {
  color: #1677ff;
}

.text-success {
  color: #07c160;
}

.text-warning {
  color: #f5a623;
}

.text-danger {
  color: #ff4d4f;
}

.text-gray {
  color: #969799;
}

/* Spacing */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* Border */
.radius {
  border-radius: 16rpx;
}

.radius-lg {
  border-radius: 24rpx;
}
