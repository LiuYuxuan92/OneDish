/* Vant Weapp 样式已通过 usingComponents 自动引入 */

page {
  background: #f7f3ec;
  color: #22342b;
  font-size: 28rpx;
  --van-button-primary-color: #274539;
  --van-primary-color: #274539;
  --van-success-color: #3d6956;
  --van-warning-color: #a87947;
  --van-danger-color: #bb6a52;
}

.container {
  padding: 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 40rpx rgba(34, 52, 43, 0.08);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #22342b;
}

.sub {
  color: #748179;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.btn {
  background: linear-gradient(135deg, #274539, #325849);
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn.secondary {
  background: rgba(255, 255, 255, 0.88);
  color: #274539;
  border: 2rpx solid rgba(39, 69, 57, 0.12);
}

.placeholder {
  color: #b7bfb9;
  font-size: 24rpx;
}

.flex { display: flex; }

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 { flex: 1; }

.text-primary { color: #274539; }
.text-success { color: #3d6956; }
.text-warning { color: #a87947; }
.text-danger { color: #bb6a52; }
.text-gray { color: #7b857f; }

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

.radius { border-radius: 18rpx; }
.radius-lg { border-radius: 28rpx; }
