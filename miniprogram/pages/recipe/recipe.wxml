<view class="container">
  <!-- 网络状态提示 -->
  <view class="offline-tip" wx:if="{{isOffline}}">
    <text>网络不可用，显示缓存数据</text>
  </view>

  <!-- 骨架屏 -->
  <skeleton type="list" wx:if="{{loading}}" />

  <!-- 菜谱列表 -->
  <view class="recipe-list" wx:if="{{!loading}}">
    <block wx:for="{{recipes}}" wx:key="id">
      <view class="recipe-card" bindtap="selectRecipe" data-id="{{item.id}}">
        <image 
          class="recipe-cover" 
          src="{{item.cover_url || '/assets/placeholder-food.png'}}" 
          mode="aspectFill"
          bindload="onImageLoad"
        />
        <view class="recipe-info">
          <view class="recipe-title">{{item.title || item.name}}</view>
          <view class="recipe-meta">
            <text wx:if="{{item.difficulty}}">{{item.difficulty}}</text>
            <text wx:if="{{item.cook_time}}">{{item.cook_time}}分钟</text>
          </view>
          <view class="recipe-desc" wx:if="{{item.description}}">
            {{item.description}}
          </view>
        </view>
      </view>
    </block>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loadingMore}}">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && recipes.length}}">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !recipes.length && !detail}}">
    <image class="empty-icon" src="/assets/empty.png" mode="aspectFit" />
    <text class="empty-text">暂无菜谱</text>
  </view>

  <!-- 详情弹窗 -->
  <view class="detail-modal" wx:if="{{detail}}" bindtap="closeDetail">
    <view class="detail-content" catchtap="preventClose">
      <view class="detail-header">
        <text class="detail-title">{{detail.title || detail.name}}</text>
        <text class="close-btn" bindtap="closeDetail">×</text>
      </view>
      <scroll-view class="detail-body" scroll-y>
        <image 
          class="detail-cover" 
          src="{{detail.cover_url || '/assets/placeholder-food.png'}}" 
          mode="aspectFill"
        />
        <view class="detail-meta">
          <text wx:if="{{detail.difficulty}}">{{detail.difficulty}}</text>
          <text wx:if="{{detail.cook_time}}">{{detail.cook_time}}分钟</text>
          <text wx:if="{{detail.calories}}">{{detail.calories}}千卡</text>
        </view>
        <view class="detail-desc" wx:if="{{detail.description}}">
          {{detail.description}}
        </view>
        
        <!-- 宝宝版 -->
        <view class="baby-section" wx:if="{{detail.baby_version}}">
          <view class="baby-title">宝宝版</view>
          <view class="baby-desc">{{detail.baby_version.description}}</view>
        </view>
      </scroll-view>
      <view class="detail-actions">
        <button class="btn-add" bindtap="addToListFromDetail">加入购物清单</button>
      </view>
    </view>
  </view>
</view>
