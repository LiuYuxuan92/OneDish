<view class="container">
  <!-- 网络状态提示 -->
  <view class="offline-tip" wx:if="{{isOffline}}">
    <text>网络不可用，显示缓存数据</text>
  </view>

  <!-- 骨架屏 -->
  <skeleton type="list" wx:if="{{loading}}" />

  <!-- 菜谱列表 -->
  <view class="recipe-list" wx:if="{{!loading}}">
    <block wx:for="{{recipes}}" wx:key="id">
      <view class="recipe-card" bindtap="selectRecipe" data-id="{{item.id}}">
        <image 
          class="recipe-cover" 
          src="{{item.cover_url || ''}}" 
          mode="aspectFill"
          bindload="onImageLoad"
        />
        <view class="recipe-info">
          <view class="recipe-title">{{item.title || item.name}}</view>
          <view class="recipe-meta">
            <text wx:if="{{item.difficulty}}">{{item.difficulty}}</text>
            <text wx:if="{{item.cook_time}}">{{item.cook_time}}分钟</text>
          </view>
          <view class="recipe-desc" wx:if="{{item.description}}">
            {{item.description}}
          </view>
        </view>
      </view>
    </block>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loadingMore}}">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && recipes.length}}">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !recipes.length && !detail}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无菜谱</text>
  </view>

  <!-- 详情弹窗 -->
  <view class="detail-modal" wx:if="{{detail}}" bindtap="closeDetail">
    <view class="detail-content" catchtap="preventClose">
      <view class="detail-header">
        <text class="detail-title">{{detail.title || detail.name}}</text>
        <text class="close-btn" bindtap="closeDetail">×</text>
      </view>
      <scroll-view class="detail-body" scroll-y>
        <image 
          class="detail-cover" 
          src="{{detail.cover_url || ''}}" 
          mode="aspectFill"
        />
        <view class="detail-meta">
          <text wx:if="{{detail.difficulty}}">{{detail.difficulty}}</text>
          <text wx:if="{{detail.cook_time}}">{{detail.cook_time}}分钟</text>
          <text wx:if="{{detail.calories}}">{{detail.calories}}千卡</text>
        </view>
        <view class="detail-desc" wx:if="{{detail.description}}">
          {{detail.description}}
        </view>
        
        <!-- 宝宝版 -->
        <view class="baby-section" wx:if="{{detail.baby_version}}">
          <view class="baby-title">宝宝版</view>
          <view class="baby-desc">{{detail.baby_version.description}}</view>
        </view>


        <view class="baby-section">
          <view class="baby-title">用餐反馈</view>
          <view class="baby-desc">先做一个最小记录：喜欢 / 一般 / 拒绝，可顺手标记是否过敏。</view>
          <view class="ai-age-selector">
            <view class="ai-age-option {{feedingAcceptedLevel === 'like' ? 'active' : ''}}" bindtap="onFeedingAcceptedLevelSelect" data-level="like">喜欢</view>
            <view class="ai-age-option {{feedingAcceptedLevel === 'ok' ? 'active' : ''}}" bindtap="onFeedingAcceptedLevelSelect" data-level="ok">一般</view>
            <view class="ai-age-option {{feedingAcceptedLevel === 'reject' ? 'active' : ''}}" bindtap="onFeedingAcceptedLevelSelect" data-level="reject">拒绝</view>
          </view>
          <checkbox-group bindchange="onFeedingAllergyChange">
            <label style="display:flex;align-items:center;margin:12rpx 0;">
              <checkbox value="1" checked="{{feedingAllergyFlag}}" />
              <text style="margin-left:12rpx;font-size:26rpx;color:#666;">这次有过敏反应</text>
            </label>
          </checkbox-group>
          <textarea placeholder="备注（可选）" value="{{feedingNote}}" bindinput="onFeedingNoteInput" style="width:100%;min-height:120rpx;background:#F7F8FA;border-radius:16rpx;padding:20rpx;box-sizing:border-box;font-size:26rpx;" />
          <button class="ai-generate-btn" bindtap="submitFeedingFeedback" style="margin-top:20rpx;">提交用餐反馈</button>
          <view wx:if="{{recentFeedingFeedbacks.length}}" style="margin-top:20rpx;">
            <view class="baby-title" style="font-size:28rpx;">最近反馈</view>
            <block wx:for="{{recentFeedingFeedbacks}}" wx:key="id">
              <view style="padding:12rpx 0;border-bottom:1rpx solid #F0F0F0;">
                <text style="font-size:24rpx;color:#333;">{{item.accepted_level === 'like' ? '喜欢' : item.accepted_level === 'ok' ? '一般' : '拒绝'}}{{item.allergy_flag ? ' · 过敏' : ''}}</text>
                <text wx:if="{{item.note}}" style="display:block;font-size:22rpx;color:#999;margin-top:6rpx;">{{item.note}}</text>
              </view>
            </block>
          </view>
        </view>

        <!-- AI 生成宝宝版本按钮 -->
        <view class="ai-generate-section">
          <button class="ai-generate-btn" bindtap="openAIGenerateModal">
            ✨ AI 生成宝宝版本
          </button>
        </view>
      </scroll-view>
      <view class="detail-actions">
        <button class="btn-add" bindtap="addToListFromDetail">加入购物清单</button>
      </view>
    </view>
  </view>

  <!-- AI 生成宝宝版本弹窗 -->
  <view class="modal-mask" wx:if="{{showAIGenerateModal}}" bindtap="closeAIGenerateModal"></view>
  <view class="ai-modal" wx:if="{{showAIGenerateModal}}">
    <view class="ai-modal-header">
      <text class="ai-modal-title">生成宝宝版本</text>
      <text class="ai-modal-close" bindtap="closeAIGenerateModal">×</text>
    </view>
    <view class="ai-modal-body">
      <!-- 宝宝月龄选择 -->
      <view class="ai-option-group">
        <text class="ai-option-label">宝宝月龄:</text>
        <view class="ai-age-selector">
          <view 
            class="ai-age-option {{selectedBabyAge === 6 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="6">
            6月
          </view>
          <view 
            class="ai-age-option {{selectedBabyAge === 8 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="8">
            8月
          </view>
          <view 
            class="ai-age-option {{selectedBabyAge === 10 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="10">
            10月
          </view>
          <view 
            class="ai-age-option {{selectedBabyAge === 12 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="12">
            12月
          </view>
          <view 
            class="ai-age-option {{selectedBabyAge === 18 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="18">
            18月
          </view>
          <view 
            class="ai-age-option {{selectedBabyAge === 24 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="24">
            24月
          </view>
        </view>
      </view>

      <!-- 生成方式选择 -->
      <view class="ai-option-group">
        <text class="ai-option-label">生成方式:</text>
        <view class="ai-mode-options">
          <view 
            class="ai-mode-option {{generateUseAI ? 'active' : ''}}" 
            bindtap="toggleGenerateMode">
            <view class="ai-radio {{generateUseAI ? 'checked' : ''}}"></view>
            <text>✨ AI 智能生成</text>
          </view>
          <view 
            class="ai-mode-option {{!generateUseAI ? 'active' : ''}}" 
            bindtap="toggleGenerateMode">
            <view class="ai-radio {{!generateUseAI ? 'checked' : ''}}"></view>
            <text>📋 规则引擎</text>
          </view>
        </view>
      </view>
    </view>
    <view class="ai-modal-footer">
      <button class="ai-modal-cancel" bindtap="closeAIGenerateModal">取消</button>
      <button 
        class="ai-modal-confirm" 
        bindtap="generateAIBabyVersion"
        loading="{{isGenerating}}">
        {{isGenerating ? '生成中...' : '开始生成'}}
      </button>
    </view>
  </view>

  <!-- AI 生成结果弹窗 -->
  <view class="modal-mask" wx:if="{{showAIResultModal}}" bindtap="closeAIResultModal"></view>
  <view class="ai-modal ai-result-modal" wx:if="{{showAIResultModal}}">
    <view class="ai-modal-header">
      <text class="ai-modal-title">✅ AI 宝宝版本已生成</text>
      <text class="ai-modal-close" bindtap="closeAIResultModal">×</text>
    </view>
    <scroll-view class="ai-result-body" scroll-y>
      <view wx:if="{{aiResult}}" class="ai-result-content">
        <!-- 配料替换 -->
        <view class="ai-result-section" wx:if="{{aiResult.ingredient_replacements && aiResult.ingredient_replacements.length}}">
          <text class="ai-result-section-title">🍚 配料替换</text>
          <block wx:for="{{aiResult.ingredient_replacements}}" wx:key="index">
            <view class="ai-result-item">
              <text class="ai-result-item-text">{{item.original}} → {{item.replacement}}</text>
              <text class="ai-result-item-reason">{{item.reason}}</text>
            </view>
          </block>
        </view>

        <!-- 质地调整 -->
        <view class="ai-result-section" wx:if="{{aiResult.texture_adjustments && aiResult.texture_adjustments.length}}">
          <text class="ai-result-section-title">👶 质地调整</text>
          <block wx:for="{{aiResult.texture_adjustments}}" wx:key="index">
            <view class="ai-result-item">
              <text class="ai-result-item-text">{{item.adjustment}}</text>
              <text class="ai-result-item-reason">{{item.reason}}</text>
            </view>
          </block>
        </view>

        <!-- 过敏提醒 -->
        <view class="ai-result-section" wx:if="{{aiResult.allergy_alerts && aiResult.allergy_alerts.length}}">
          <text class="ai-result-section-title">⚠️ 过敏提醒</text>
          <block wx:for="{{aiResult.allergy_alerts}}" wx:key="index">
            <view class="ai-result-alert">
              <text>{{item}}</text>
            </view>
          </block>
        </view>

        <!-- 营养提示 -->
        <view class="ai-result-section" wx:if="{{aiResult.nutrition_tips}}">
          <text class="ai-result-section-title">💡 营养提示</text>
          <text class="ai-result-nutrition">{{aiResult.nutrition_tips}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="ai-modal-footer">
      <button class="ai-modal-cancel" bindtap="closeAIResultModal">关闭</button>
    </view>
  </view>
</view>
