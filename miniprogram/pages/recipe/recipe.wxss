.container {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 140rpx;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Empty */
.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.empty-text {
  color: #999;
}

/* Cover */
.cover {
  width: 100%;
  height: 400rpx;
}

/* Version Tabs */
.version-tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.version-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f7fb;
}

.version-tabs .tab.active {
  background: #1677ff;
  color: #fff;
  font-weight: 600;
}

/* Header */
.header {
  background: #fff;
  padding: 24rpx;
}

.header .title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.badge {
  font-size: 22rpx;
  color: #07c160;
  background: #e6f7f0;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: normal;
}

.meta {
  display: flex;
  gap: 16rpx;
  color: #999;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.desc {
  color: #666;
  font-size: 28rpx;
  line-height: 1.6;
}

.baby-age {
  margin-top: 16rpx;
  color: #07c160;
  font-size: 26rpx;
}

/* Tab Bar */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  padding: 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1677ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}

/* Section */
.section {
  background: #fff;
  padding: 24rpx;
  margin-top: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* Ingredients */
.ingredients-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  background: #f5f7fb;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
}

.ingredient-item .quantity {
  color: #1677ff;
  margin-left: 8rpx;
}

.empty-tip {
  color: #999;
  text-align: center;
  padding: 40rpx;
}

/* Steps */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  gap: 16rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

/* Bottom Actions */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 16rpx;
}

.btn-add {
  flex: 2;
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.btn-favorite {
  flex: 1;
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-favorite.active {
  color: #ff4d4f;
  border-color: #ff4d4f;
}
