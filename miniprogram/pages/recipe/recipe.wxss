.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(255, 236, 206, 0.42), transparent 30%),
    linear-gradient(180deg, #f5efe6 0%, #f2f6f1 30%, #f2f6f1 100%);
  padding-bottom: 148rpx;
}

.offline-tip {
  margin: 20rpx 24rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff3dc;
  color: #b67821;
  text-align: center;
  font-size: 24rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(39, 69, 57, 0.12);
  border-top-color: #274539;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 18rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 140rpx 48rpx;
}

.empty-text {
  color: #819087;
  font-size: 28rpx;
}

.recipe-shell {
  padding: 24rpx;
}

.recipe-page-hero {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 30rpx 28rpx 32rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 224, 182, 0.8), transparent 34%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(252, 248, 242, 0.98));
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 18rpx 38rpx rgba(28, 41, 35, 0.08);
}

.recipe-page-copy {
  flex: 1;
  min-width: 0;
}

.recipe-page-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf3ef;
  color: #66756d;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.recipe-page-title {
  display: block;
  margin-top: 18rpx;
  color: #22352d;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
}

.recipe-page-desc {
  display: block;
  margin-top: 14rpx;
  color: #6b7972;
  font-size: 24rpx;
  line-height: 1.7;
}

.recipe-page-badge {
  align-self: flex-start;
  flex-shrink: 0;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #274539, #35584c);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 28rpx rgba(39, 69, 57, 0.18);
}

.recipe-page-highlights {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.recipe-page-highlight {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 12rpx 24rpx rgba(28, 41, 35, 0.05);
}

.recipe-page-highlight.soft {
  background: rgba(248, 241, 230, 0.92);
}

.recipe-page-highlight-value {
  display: block;
  color: #22352d;
  font-size: 28rpx;
  font-weight: 700;
}

.recipe-page-highlight-label {
  display: block;
  margin-top: 8rpx;
  color: #7a847d;
  font-size: 20rpx;
}

.recipe-list {
  margin-top: 20rpx;
}

.recipe-card {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 18rpx 36rpx rgba(34, 48, 41, 0.08);
}

.recipe-card.no-cover {
  background:
    radial-gradient(circle at top right, rgba(236, 241, 255, 0.86), transparent 36%),
    rgba(255, 255, 255, 0.95);
}

.recipe-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.recipe-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.recipe-collection-label {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #edf3ef;
  color: #5f7067;
  font-size: 20rpx;
  font-weight: 700;
}

.recipe-cta {
  color: #8b6638;
  font-size: 22rpx;
  font-weight: 700;
}

.recipe-title {
  margin-top: 16rpx;
  color: #22342c;
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 700;
}

.recipe-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.recipe-meta text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #67766e;
  font-size: 22rpx;
}

.recipe-desc {
  margin-top: 14rpx;
  color: #728078;
  font-size: 25rpx;
  line-height: 1.68;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.recipe-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: auto;
  padding-top: 18rpx;
}

.recipe-footer-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6f4;
  color: #697770;
  font-size: 20rpx;
}

.recipe-footer-pill.warm {
  background: #fff2df;
  color: #ac6d24;
}

.recipe-visual {
  width: 180rpx;
  flex-shrink: 0;
}

.recipe-card.no-cover .recipe-visual {
  width: 144rpx;
}

.recipe-cover {
  width: 100%;
  height: 100%;
  min-height: 208rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e8ede7, #dbe3dc);
}

.recipe-cover-fallback {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 18rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 219, 176, 0.72), transparent 32%),
    linear-gradient(145deg, #edf2f8, #e7eee9);
}

.recipe-cover-kicker {
  position: relative;
  z-index: 1;
  color: #6c7886;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.recipe-cover-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: #23342d;
  font-size: 24rpx;
  line-height: 1.34;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.recipe-cover-copy {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 10rpx;
  color: #728079;
  font-size: 20rpx;
  line-height: 1.55;
}

.recipe-cover-orb {
  position: absolute;
  top: 18rpx;
  right: 16rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.28);
}

.loading-more,
.no-more {
  padding: 28rpx 0 8rpx;
  text-align: center;
  color: #88958e;
  font-size: 24rpx;
}

.detail-modal {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(16, 24, 21, 0.52);
}

.detail-content {
  position: absolute;
  top: 28rpx;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(100vh - 28rpx);
  display: flex;
  flex-direction: column;
}

.detail-sheet {
  height: 100%;
  border-radius: 40rpx 40rpx 0 0;
  background:
    radial-gradient(circle at top right, rgba(255, 220, 164, 0.34), transparent 26%),
    linear-gradient(180deg, #f7f2e9 0%, #f4f7f3 32%, #f4f7f3 100%);
  box-shadow: 0 -24rpx 56rpx rgba(17, 29, 24, 0.18);
  overflow: hidden;
}

.detail-scroll {
  flex: none;
  height: calc(100vh - 292rpx - env(safe-area-inset-bottom));
  padding: 0 0 36rpx;
}

.detail-body {
  box-sizing: border-box;
}

.detail-top-stack {
  margin: 22rpx 22rpx 0;
}

.detail-header-card {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 26rpx 24rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 222, 175, 0.82), transparent 34%),
    linear-gradient(135deg, #fffaf1, #ffffff);
  box-shadow: 0 14rpx 32rpx rgba(28, 41, 35, 0.08);
}

.detail-header-main {
  flex: 1;
  min-width: 0;
}

.detail-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf3ef;
  color: #66756d;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.detail-page-title {
  display: block;
  margin-top: 18rpx;
  color: #22352d;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 700;
}

.detail-page-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6f7b75;
  font-size: 24rpx;
  line-height: 1.68;
}

.close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn-soft {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #f3f6f4;
  color: #71807a;
  font-size: 44rpx;
  line-height: 1;
}

.detail-cover-card {
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #e2e8e3;
  box-shadow: 0 14rpx 30rpx rgba(28, 41, 35, 0.08);
}

.detail-inline-cover {
  width: 100%;
  height: 236rpx;
}

.detail-cover-card-fallback {
  background:
    radial-gradient(circle at top right, rgba(255, 228, 188, 0.78), transparent 34%),
    linear-gradient(135deg, #f4f6fb, #edf4ef);
}

.detail-cover-fallback {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 24rpx;
}

.detail-cover-copy {
  flex: 1;
  min-width: 0;
}

.detail-cover-kicker {
  color: #6a7886;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.detail-cover-heading {
  display: block;
  margin-top: 12rpx;
  color: #22352d;
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 700;
}

.detail-cover-summary {
  display: block;
  margin-top: 12rpx;
  color: #6e7c75;
  font-size: 23rpx;
  line-height: 1.68;
}

.detail-cover-stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 152rpx;
  flex-shrink: 0;
}

.detail-cover-stat {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.7);
  text-align: center;
}

.detail-cover-stat-value {
  display: block;
  color: #22352d;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-cover-stat-label {
  display: block;
  margin-top: 8rpx;
  color: #7e8a84;
  font-size: 20rpx;
}

.detail-feedback {
  margin: 16rpx 22rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 24rpx rgba(28, 41, 35, 0.08);
}

.detail-feedback-success {
  background: linear-gradient(135deg, #e8f8ee, #f4fbf7);
  color: #23613f;
}

.detail-feedback-info {
  background: linear-gradient(135deg, #eef3ef, #f8fbf8);
  color: #486154;
}

.detail-feedback-text {
  font-size: 24rpx;
  line-height: 1.62;
}

.detail-overview-panel {
  display: flex;
  gap: 14rpx;
  margin: 16rpx 22rpx 0;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(28, 41, 35, 0.1);
}

.overview-stat {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f7f9f8, #eef4f0);
  text-align: center;
}

.overview-value {
  display: block;
  color: #21342c;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
  word-break: break-all;
}

.overview-label {
  display: block;
  margin-top: 10rpx;
  color: #7b8881;
  font-size: 22rpx;
}

.detail-quick-actions {
  display: flex;
  gap: 14rpx;
  margin: 16rpx 22rpx 0;
}

.detail-quick-card {
  flex: 1;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(28, 41, 35, 0.06);
}

.detail-quick-card.primary {
  background: linear-gradient(135deg, #234033, #345846);
}

.detail-quick-card.warm {
  background: linear-gradient(135deg, #fff2df, #f7e6cb);
}

.detail-quick-card.save {
  background: linear-gradient(135deg, #fff7eb, #f8ead3);
}

.detail-quick-card.save.disabled {
  opacity: 0.7;
}

.detail-quick-card.soft {
  background: linear-gradient(135deg, #f3f6f4, #edf3ef);
}

.detail-quick-card.soft.active {
  background: linear-gradient(135deg, #e7f7ed, #eff9f2);
}

.detail-quick-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.detail-quick-card.primary .detail-quick-title {
  color: #ffffff;
}

.detail-quick-card.warm .detail-quick-title {
  color: #7f5725;
}

.detail-quick-card.save .detail-quick-title {
  color: #8a602d;
}

.detail-quick-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.58;
}

.detail-quick-card.primary .detail-quick-desc {
  color: rgba(255, 255, 255, 0.74);
}

.detail-quick-card.warm .detail-quick-desc {
  color: #936c43;
}

.detail-quick-card.save .detail-quick-desc {
  color: #9b7548;
}

.detail-quick-card.soft .detail-quick-title {
  color: #294136;
}

.detail-quick-card.soft .detail-quick-desc {
  color: #627068;
}

.detail-quick-card.soft.active .detail-quick-title {
  color: #23784a;
}

.detail-quick-card.soft.active .detail-quick-desc {
  color: #3f6a4f;
}

.detail-quick-tip {
  display: block;
  margin: 14rpx 24rpx 0;
  color: #8a775d;
  font-size: 22rpx;
  line-height: 1.6;
}

.detail-card {
  margin: 18rpx 22rpx 0;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 30rpx rgba(25, 37, 32, 0.06);
}

.intro-card {
  background:
    radial-gradient(circle at top right, rgba(234, 242, 255, 0.9), transparent 36%),
    rgba(255, 255, 255, 0.94);
}

.detail-card-warm {
  background:
    radial-gradient(circle at top right, rgba(255, 233, 197, 0.72), transparent 34%),
    linear-gradient(180deg, #fffaf2 0%, #fffef9 100%);
}

.detail-card-focus {
  box-shadow: 0 0 0 3rpx rgba(234, 176, 74, 0.34), 0 18rpx 36rpx rgba(190, 126, 26, 0.14);
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.detail-section-title {
  color: #22352d;
  font-size: 30rpx;
  font-weight: 700;
}

.section-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #edf2ee;
  color: #617169;
  font-size: 20rpx;
}

.section-badge.warm {
  background: #fff0d7;
  color: #a96a20;
}

.section-badge.subtle {
  background: #edf3ff;
  color: #6f7b75;
}

.detail-card-copy {
  display: block;
  margin-top: 14rpx;
  color: #68776f;
  font-size: 25rpx;
  line-height: 1.72;
}

.intro-note {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #fff5e5, #fffaf3);
}

.intro-note-label {
  display: block;
  color: #9a6a31;
  font-size: 22rpx;
  font-weight: 700;
}

.intro-note-copy {
  display: block;
  margin-top: 10rpx;
  color: #8e6a43;
  font-size: 24rpx;
  line-height: 1.68;
}

.detail-card-tip {
  display: block;
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #fff2dc;
  color: #9f6d32;
  font-size: 23rpx;
  line-height: 1.68;
}

.detail-subcard {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(168, 120, 64, 0.14);
}

.detail-subtitle-label {
  display: block;
  margin-bottom: 14rpx;
  color: #7e5a30;
  font-size: 24rpx;
  font-weight: 700;
}

.ingredients-list {
  display: flex;
  flex-wrap: wrap;
}

.ingredient-grid {
  gap: 14rpx;
  margin-top: 18rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
}

.ingredient-pill {
  min-width: 190rpx;
  max-width: 100%;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #eef4f0;
  box-sizing: border-box;
}

.ingredient-pill.baby {
  background: #fff1dd;
}

.ingredient-name {
  flex: 1;
  min-width: 0;
  color: #284036;
  font-size: 25rpx;
}

.quantity {
  color: #486154;
  font-size: 24rpx;
  font-weight: 700;
}

.steps-list {
  display: flex;
  flex-direction: column;
}

.steps-timeline {
  gap: 14rpx;
  margin-top: 18rpx;
}

.step-item {
  position: relative;
  display: flex;
  gap: 18rpx;
}

.step-card {
  padding: 6rpx 0 6rpx 10rpx;
}

.step-line {
  position: absolute;
  top: 36rpx;
  left: 34rpx;
  bottom: -20rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(39, 69, 57, 0.28), rgba(39, 69, 57, 0.02));
}

.step-item:last-child .step-line {
  display: none;
}

.step-line.baby {
  background: linear-gradient(180deg, rgba(228, 162, 53, 0.34), rgba(228, 162, 53, 0.02));
}

.step-num {
  position: relative;
  z-index: 1;
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #274539, #325849);
  box-shadow: 0 10rpx 18rpx rgba(39, 69, 57, 0.22);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.step-num.baby {
  background: linear-gradient(135deg, #f1b64a, #dc9225);
  box-shadow: 0 10rpx 18rpx rgba(219, 146, 37, 0.2);
}

.step-main {
  flex: 1;
  min-width: 0;
  padding: 6rpx 0 16rpx;
}

.step-content {
  color: #22352d;
  font-size: 28rpx;
  line-height: 1.72;
}

.step-meta {
  display: block;
  margin-top: 10rpx;
  color: #8a9690;
  font-size: 22rpx;
  line-height: 1.5;
}

.baby-empty {
  margin-top: 18rpx;
  padding: 26rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 2rpx dashed rgba(222, 156, 57, 0.28);
}

.baby-empty-title {
  display: block;
  color: #855821;
  font-size: 28rpx;
  font-weight: 700;
}

.baby-empty-copy {
  display: block;
  margin-top: 12rpx;
  color: #8d714f;
  font-size: 24rpx;
  line-height: 1.68;
}

.baby-empty-btn {
  margin-top: 18rpx;
  padding: 22rpx 0;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2b245, #db8d1e);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
}

.baby-empty-btn::after {
  border: none;
}

.feedback-card {
  background:
    radial-gradient(circle at top right, rgba(228, 244, 237, 0.78), transparent 34%),
    rgba(255, 255, 255, 0.94);
}

.feedback-options {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.feedback-chip {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 20rpx;
  background: #f2f5f4;
  color: #66746d;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.feedback-chip.active.like {
  background: #e7f7ed;
  color: #23784a;
}

.feedback-chip.active.ok {
  background: #edf3ff;
  color: #486154;
}

.feedback-chip.active.reject {
  background: #fff0ec;
  color: #bb5b45;
}

.feedback-checkbox-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.feedback-checkbox-label {
  margin-left: 12rpx;
  color: #68766e;
  font-size: 24rpx;
}

.feedback-textarea {
  width: 100%;
  min-height: 150rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #f3f7f5;
  color: #24352d;
  font-size: 25rpx;
  line-height: 1.6;
}

.feedback-submit-btn,
.ai-entry-btn {
  width: 100%;
  margin-top: 18rpx;
  padding: 22rpx 0;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.feedback-submit-btn {
  background: linear-gradient(135deg, #2d5c48, #244238);
  color: #ffffff;
}

.feedback-submit-btn::after,
.ai-entry-btn::after {
  border: none;
}

.feedback-history {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #ecf1ee;
}

.feedback-history-title {
  color: #466057;
}

.feedback-history-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f4f1;
}

.feedback-history-item:last-child {
  border-bottom: none;
}

.feedback-history-main {
  display: block;
  color: #2d3f37;
  font-size: 24rpx;
  line-height: 1.55;
}

.feedback-history-note {
  display: block;
  margin-top: 8rpx;
  color: #87938d;
  font-size: 22rpx;
  line-height: 1.55;
}

.ai-card {
  margin-bottom: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(223, 231, 255, 0.86), transparent 34%),
    rgba(255, 255, 255, 0.94);
}

.ai-entry-btn {
  background: linear-gradient(135deg, #8d6a40, #a17b4e);
  color: #ffffff;
}

.ai-card-points {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.ai-card-point {
  display: block;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #65736b;
  font-size: 22rpx;
  line-height: 1.55;
}

.detail-actions {
  flex-shrink: 0;
}

.detail-actions-bar {
  padding: 20rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(212, 220, 215, 0.8);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 28rpx rgba(24, 37, 32, 0.08);
}

.detail-action-copy {
  margin-bottom: 14rpx;
}

.detail-action-title {
  display: block;
  color: #24352d;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-action-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #7d8883;
  font-size: 22rpx;
}

.btn-add {
  padding: 24rpx 0;
  border-radius: 999rpx;
  border: none;
}

.btn-add::after {
  border: none;
}

.detail-primary-btn {
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(39, 69, 57, 0.22);
  font-size: 30rpx;
  font-weight: 700;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(15, 24, 20, 0.52);
}

.ai-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 620rpx;
  z-index: 201;
  overflow: hidden;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(232, 239, 255, 0.86), transparent 34%),
    #ffffff;
  box-shadow: 0 24rpx 52rpx rgba(20, 31, 26, 0.16);
}

.ai-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #e8ede8;
}

.ai-modal-title {
  color: #24352d;
  font-size: 32rpx;
  font-weight: 700;
}

.ai-modal-close {
  color: #84918b;
  font-size: 44rpx;
  line-height: 1;
}

.ai-modal-body {
  padding: 24rpx;
}

.ai-option-group {
  margin-bottom: 24rpx;
}

.ai-option-group:last-child {
  margin-bottom: 0;
}

.ai-option-label {
  display: block;
  margin-bottom: 14rpx;
  color: #274539;
  font-size: 27rpx;
  font-weight: 700;
}

.ai-option-help {
  display: block;
  margin: -2rpx 0 14rpx;
  color: #7b8782;
  font-size: 22rpx;
  line-height: 1.6;
}

.ai-age-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ai-age-option {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f6f4;
  color: #64716b;
  font-size: 24rpx;
}

.ai-age-option.active {
  background: #eef3ef;
  color: #274539;
}

.ai-mode-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ai-mode-option {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f4f7f5;
  color: #627069;
  font-size: 25rpx;
}

.ai-mode-option.active {
  background: #eef3ef;
  color: #486154;
}

.ai-mode-copy {
  flex: 1;
  min-width: 0;
}

.ai-mode-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ai-mode-title {
  display: block;
  color: #2b3e35;
  font-size: 25rpx;
  font-weight: 700;
}

.ai-mode-desc {
  display: block;
  margin-top: 8rpx;
  color: #738078;
  font-size: 21rpx;
  line-height: 1.55;
}

.ai-mode-badge {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #efe6d8;
  color: #6f552e;
  font-size: 18rpx;
  font-weight: 700;
}

.ai-radio {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  border: 2rpx solid #c8d0cb;
  border-radius: 50%;
}

.ai-radio.checked {
  border-color: #274539;
  background: radial-gradient(circle, #274539 0, #274539 42%, transparent 46%);
}

.ai-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #e8ede8;
}

.ai-modal-cancel,
.ai-modal-confirm {
  flex: 1;
  padding: 22rpx 0;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.ai-modal-cancel {
  background: #f3f6f4;
  color: #66746d;
}

.ai-modal-confirm {
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
}

.ai-modal-cancel::after,
.ai-modal-confirm::after {
  border: none;
}

.ai-result-modal {
  width: 650rpx;
  max-height: 72vh;
}

.ai-result-body {
  max-height: 52vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.ai-result-content {
  padding-bottom: 12rpx;
}

.ai-result-section {
  margin-bottom: 24rpx;
}

.ai-result-section:last-child {
  margin-bottom: 0;
}

.ai-result-section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #2a3d34;
  font-size: 27rpx;
  font-weight: 700;
}

.ai-result-item {
  margin-bottom: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #f4f6f2;
}

.ai-result-item-text {
  display: block;
  color: #2a3d34;
  font-size: 25rpx;
  line-height: 1.58;
}

.ai-result-item-reason {
  display: block;
  margin-top: 8rpx;
  color: #78858a;
  font-size: 22rpx;
  line-height: 1.58;
}

.ai-result-alert {
  margin-bottom: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #fff1ee;
}

.ai-result-alert text {
  color: #bb5d49;
  font-size: 24rpx;
  line-height: 1.55;
}

.ai-result-nutrition {
  color: #66746d;
  font-size: 24rpx;
  line-height: 1.72;
}

.ai-modal-quota {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff7ef;
}

.ai-modal-quota-value {
  display: block;
  color: #8f5717;
  font-size: 32rpx;
  font-weight: 700;
}

.ai-modal-quota-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a7750;
  font-size: 21rpx;
  line-height: 1.6;
}
