.container {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 140rpx;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
  color: #999;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Empty */
.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.empty-text {
  color: #999;
}

/* Cover */
.cover {
  width: 100%;
  height: 400rpx;
}

/* Version Tabs */
.version-tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.version-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f7fb;
}

.version-tabs .tab.active {
  background: #1677ff;
  color: #fff;
  font-weight: 600;
}

/* Header */
.header {
  background: #fff;
  padding: 24rpx;
}

.header .title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.badge {
  font-size: 22rpx;
  color: #07c160;
  background: #e6f7f0;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: normal;
}

.meta {
  display: flex;
  gap: 16rpx;
  color: #999;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.desc {
  color: #666;
  font-size: 28rpx;
  line-height: 1.6;
}

.baby-age {
  margin-top: 16rpx;
  color: #07c160;
  font-size: 26rpx;
}

/* Tab Bar */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  padding: 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1677ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 2rpx;
}

/* Section */
.section {
  background: #fff;
  padding: 24rpx;
  margin-top: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* Ingredients */
.ingredients-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  background: #f5f7fb;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
}

.ingredient-item .quantity {
  color: #1677ff;
  margin-left: 8rpx;
}

.empty-tip {
  color: #999;
  text-align: center;
  padding: 40rpx;
}

/* Steps */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  gap: 16rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

/* Bottom Actions */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 16rpx;
}

.btn-add {
  flex: 2;
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.btn-favorite {
  flex: 1;
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-favorite.active {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

/* Phase 3: 骨架屏 + 离线缓存 + 网络状态 */
.container {
  min-height: 100vh;
  background: #f5f7fb;
}

/* Offline Tip */
.offline-tip {
  background: #fff7e6;
  color: #f5a623;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
}

/* Recipe List (for list view) */
.recipe-list {
  padding: 24rpx;
}

.recipe-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.recipe-cover {
  width: 100%;
  height: 300rpx;
  background: #f5f7fb;
}

.recipe-info {
  padding: 20rpx;
}

.recipe-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.recipe-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.recipe-meta text {
  font-size: 24rpx;
  color: #999;
  background: #f5f7fb;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.recipe-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* Loading More */
.loading-more, .no-more {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 26rpx;
}

/* Detail Modal */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.detail-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.detail-body {
  flex: 1;
  padding: 24rpx;
  max-height: 60vh;
}

.detail-cover {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.detail-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-meta text {
  font-size: 24rpx;
  color: #999;
  background: #f5f7fb;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.detail-actions {
  padding: 24rpx;
  border-top: 1rpx solid #eee;
}

/* ========== AI 宝宝版本生成样式 ========== */
.ai-generate-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.ai-generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.ai-generate-btn::after {
  border: none;
}

/* Modal Mask */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

/* AI Modal */
.ai-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 24rpx;
  width: 600rpx;
  z-index: 201;
  overflow: hidden;
}

.ai-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.ai-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.ai-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.ai-modal-body {
  padding: 24rpx;
}

.ai-option-group {
  margin-bottom: 24rpx;
}

.ai-option-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.ai-age-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ai-age-option {
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
  background: #f5f7fb;
  border: 1rpx solid #e5e7eb;
  font-size: 26rpx;
  color: #666;
}

.ai-age-option.active {
  background: #e6f4ff;
  border-color: #1677ff;
  color: #1677ff;
}

.ai-mode-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ai-mode-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #f5f7fb;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #666;
}

.ai-mode-option.active {
  background: #e6f4ff;
  border-color: #1677ff;
  color: #1677ff;
}

.ai-radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-radio.checked {
  border-color: #1677ff;
}

.ai-radio.checked::after {
  content: '';
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #1677ff;
}

.ai-modal-footer {
  display: flex;
  padding: 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid #eee;
}

.ai-modal-cancel {
  flex: 1;
  background: #f5f7fb;
  color: #666;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.ai-modal-confirm {
  flex: 1;
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

/* AI Result Modal */
.ai-result-modal {
  width: 650rpx;
  max-height: 70vh;
}

.ai-result-body {
  max-height: 50vh;
  padding: 24rpx;
}

.ai-result-content {
  padding-bottom: 24rpx;
}

.ai-result-section {
  margin-bottom: 24rpx;
}

.ai-result-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.ai-result-item {
  padding: 12rpx 0;
  border-left: 4rpx solid #e6f4ff;
  padding-left: 12rpx;
  margin-bottom: 8rpx;
}

.ai-result-item-text {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.ai-result-item-reason {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.ai-result-alert {
  background: #fff2f0;
  border-radius: 8rpx;
  padding: 12rpx;
  margin-bottom: 8rpx;
}

.ai-result-alert text {
  font-size: 26rpx;
  color: #ff4d4f;
}

.ai-result-nutrition {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
