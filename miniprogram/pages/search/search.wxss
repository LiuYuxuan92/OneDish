.container {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
}

/* Search Bar */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

/* History */
.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-header .title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.history-header .clear {
  font-size: 26rpx;
  color: #1677ff;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-item {
  background: #f5f7fb;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

/* Results */
.results {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.results-header {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.results-subtitle {
  display: block;
  font-size: 22rpx;
  color: #c48a15;
  margin-top: 8rpx;
  line-height: 1.5;
}

.result-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f7fb;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.result-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.result-meta text {
  font-size: 24rpx;
  color: #999;
  background: #f5f7fb;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-preference-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b26b00;
  background: #fff7e8;
  border-radius: 12rpx;
  padding: 10rpx 14rpx;
  line-height: 1.5;
}

.no-result {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  color: #999;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
