.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(190, 224, 205, 0.48), transparent 34%),
    radial-gradient(circle at top right, rgba(244, 219, 184, 0.24), transparent 24%),
    linear-gradient(180deg, #f2f6ef 0%, #f5f7fb 34%, #f4f7f3 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero,
.search-panel,
.assist-card,
.history-card,
.loading-card,
.results-card,
.empty-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 16rpx 36rpx rgba(35, 64, 51, 0.08);
}

.hero {
  padding: 30rpx 30rpx 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 226, 194, 0.76), transparent 34%),
    rgba(255, 255, 255, 0.96);
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(53, 95, 78, 0.12);
  color: #2d4c40;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 46rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #203328;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: #637068;
}

.preference-chip {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  background: #f7efe1;
  color: #90612f;
  font-size: 22rpx;
}

.hero-meta-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.hero-meta-card {
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
}

.hero-meta-label {
  display: block;
  color: #7b877f;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.hero-meta-value {
  display: block;
  margin-top: 10rpx;
  color: #203328;
  font-size: 24rpx;
  line-height: 1.58;
  font-weight: 600;
}

.search-panel {
  margin-top: 18rpx;
  padding: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 999rpx;
  background: #f2f5f3;
  border: 1rpx solid rgba(39, 69, 57, 0.05);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #22342b;
}

.search-submit {
  margin-top: 16rpx;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2c4a3d, #3f6855);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.assist-card {
  margin-top: 18rpx;
  padding: 20rpx;
}

.feedback-banner {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 30rpx rgba(35, 64, 51, 0.08);
}

.feedback-banner-info {
  background: linear-gradient(135deg, #eef4ff, #fbfdff);
  color: #335d9b;
}

.feedback-banner-success {
  background: linear-gradient(135deg, #edf8f0, #fbfffc);
  color: #2d6b43;
}

.feedback-banner text {
  display: block;
  font-size: 24rpx;
  line-height: 1.62;
}

.inventory-toggle {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f7f6;
  border: 1rpx solid rgba(39, 69, 57, 0.05);
}

.inventory-toggle.active {
  background: linear-gradient(135deg, #e7f3eb, #eff7f1);
}

.assist-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #203328;
}

.assist-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #748078;
}

.assist-switch {
  align-self: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #203328;
  color: #ffffff;
  font-size: 20rpx;
}

.scenario-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.scenario-list {
  display: inline-flex;
  gap: 14rpx;
}

.scenario-chip {
  display: inline-flex;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #eef2ef;
  color: #54635b;
  font-size: 24rpx;
}

.scenario-chip.quick {
  background: #eef4ef;
}

.scenario-chip.light {
  background: #f6f1e8;
}

.scenario-chip.appetite {
  background: #f2f0f8;
}

.scenario-chip.fish {
  background: #edf4f7;
}

.scenario-chip.active {
  background: #2f5142;
  color: #ffffff;
}

.scenario-chip.quick.active {
  background: #315646;
}

.scenario-chip.light.active {
  background: #9a6a34;
}

.scenario-chip.appetite.active {
  background: #6a5b87;
}

.scenario-chip.fish.active {
  background: #3a6b74;
}

.history-card,
.loading-card,
.results-card,
.empty-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #203328;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d6533;
}

.section-link {
  font-size: 24rpx;
  color: #355f4e;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.history-item {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f0f3f1;
  color: #4f5d56;
  font-size: 24rpx;
}

.loading-card,
.empty-card {
  text-align: center;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  margin: 8rpx auto 20rpx;
  border: 4rpx solid rgba(53, 95, 78, 0.14);
  border-top-color: #355f4e;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #24342b;
}

.loading-desc,
.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #748078;
}

.result-item {
  display: flex;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0ee;
}

.result-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.result-cover {
  width: 164rpx;
  height: 132rpx;
  border-radius: 20rpx;
  background: #e7ece9;
  flex-shrink: 0;
}

.result-cover-fallback {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 18rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 225, 190, 0.72), transparent 34%),
    linear-gradient(135deg, #f1f4f8, #e8efe9);
}

.result-cover-kicker {
  color: #77838f;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.result-cover-copy {
  display: block;
  margin-top: 10rpx;
  color: #24342b;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 700;
}

.result-main {
  flex: 1;
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.36;
  color: #22342b;
}

.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.result-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef2ef;
  color: #355f4e;
  font-size: 20rpx;
}

.source-tag.local {
  background: #edf5ee;
  color: #2e5a49;
}

.source-tag.external {
  background: #fff4e8;
  color: #a0611e;
}

.result-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.68;
  color: #67746c;
}

.result-source-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.58;
  color: #7a6c55;
}

.result-hint {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #fff6ea;
  color: #8b6331;
  font-size: 22rpx;
  line-height: 1.6;
}

.result-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.result-action-button {
  margin: 0;
  padding: 0 24rpx;
  min-width: 0;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.result-action-button::after {
  border-radius: 999rpx;
}

.result-action-button.primary {
  background: linear-gradient(135deg, #2c4a3d, #3f6855);
  color: #ffffff;
}

.result-action-button.secondary {
  background: #ffffff;
  color: #355f4e;
  border-color: rgba(53, 95, 78, 0.2);
}
