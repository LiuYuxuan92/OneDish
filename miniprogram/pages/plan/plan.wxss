.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* Tab Bar */
.tab-bar {
  display: flex;
  background: #f5f7fb;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.tab-bar .tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.tab-bar .tab.active {
  background: #fff;
  color: #1677ff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* Add Section */
.add-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.add-section .input {
  flex: 1;
  margin: 0;
}

.btn-add {
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

/* List Header */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.clear-btn {
  color: #1677ff;
  font-size: 26rpx;
}

/* List Item */
.list-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.list-item .item-text {
  flex: 1;
  font-size: 28rpx;
}

.list-item .item-text.done {
  text-decoration: line-through;
  color: #999;
}

.item-quantity {
  color: #999;
  font-size: 24rpx;
  margin-left: 8rpx;
}

.delete-btn {
  color: #ff4d4f;
  font-size: 36rpx;
  padding: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* Share Section */
.share-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-share {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
  width: 100%;
}

/* History */
.history-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.history-items {
  font-size: 28rpx;
  color: #333;
}

/* Debug Section */
.debug-section {
  margin-top: 40rpx;
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.debug-toggle {
  font-size: 26rpx;
  color: #999;
}

.debug-content {
  margin-top: 16rpx;
}

.debug-content .input {
  margin-bottom: 12rpx;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin: 12rpx 0;
  background: #fff;
}

.add-row {
  display: flex;
  gap: 12rpx;
}

.add-row .input {
  flex: 1;
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-text {
  flex: 1;
}

.item-text.done {
  text-decoration: line-through;
  color: #999;
}

.source {
  color: #999;
  font-size: 22rpx;
}

.list-header {
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.no-items {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.empty-state text {
  color: #999;
  margin-bottom: 24rpx;
}

.btn-login {
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.btn {
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
}

.btn.secondary {
  background: #edf3ff;
  color: #1677ff;
}

.btn.primary {
  background: #07c160;
  color: #fff;
  margin-top: 16rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 600rpx;
  z-index: 101;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-content {
  margin-bottom: 32rpx;
}

.invite-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f7fb;
  border-radius: 16rpx;
  padding: 32rpx;
}

.invite-code-box .label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.invite-code-box .code {
  font-size: 48rpx;
  font-weight: bold;
  color: #1677ff;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
}

.btn-copy {
  background: #1677ff;
  color: #fff;
  border-radius: 32rpx;
  padding: 12rpx 40rpx;
  font-size: 26rpx;
}

.divider-text {
  text-align: center;
  color: #999;
  margin: 32rpx 0;
  font-size: 26rpx;
}

.btn-wechat-share {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.modal-close {
  background: #f5f7fb;
  color: #666;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
}
