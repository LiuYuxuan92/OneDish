<view class="container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view 
      class="tab {{activeTab === 'current' ? 'active' : ''}}" 
      bindtap="onTabSwitch" 
      data-tab="current">
      当前清单
    </view>
    <view 
      class="tab {{activeTab === 'history' ? 'active' : ''}}" 
      bindtap="onTabSwitch" 
      data-tab="history">
      历史清单
    </view>
  </view>

  <!-- 当前清单 -->
  <view wx:if="{{activeTab === 'current'}}">
    <!-- 添加区域 -->
    <view class="add-section">
      <input 
        class="input" 
        placeholder="添加食材..." 
        value="{{newItem}}" 
        bindinput="onNewItemInput" 
        bindconfirm="addItem"
      />
      <button class="btn-add" bindtap="addItem">添加</button>
    </view>

    <!-- 清单列表 -->
    <view class="list-header">
      <text>清单 ({{items.length}})</text>
      <text class="clear-btn" bindtap="clearChecked">清除已购</text>
    </view>

    <block wx:for="{{items}}" wx:key="index">
      <view class="list-item">
        <checkbox 
          checked="{{item.checked}}" 
          data-index="{{index}}" 
          bindtap="toggleItem"
          color="#1677ff"
        />
        <view class="item-text {{item.checked ? 'done' : ''}}">
          {{item.name}}
          <text class="item-quantity" wx:if="{{item.quantity}}">{{item.quantity}}{{item.unit}}</text>
        </view>
        <view class="delete-btn" data-index="{{index}}" bindtap="deleteItem">×</view>
      </view>
    </block>

    <view wx:if="{{!items.length}}" class="empty-tip">
      <text>清单为空，快去添加吧～</text>
    </view>

    <!-- 分享按钮 -->
    <view class="share-section">
      <button class="btn-share" bindtap="onShare">分享清单给家人</button>
    </view>
  </view>

  <!-- 历史清单 -->
  <view wx:if="{{activeTab === 'history'}}">
    <block wx:for="{{history}}" wx:key="index">
      <view class="history-item">
        <view class="history-date">{{item.date}}</view>
        <view class="history-items">
          <text wx:for="{{item.items}}" wx:for-item="i" wx:key="*this">{{i.name}}{{index < item.items.length - 1 ? '、' : ''}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!history.length}}" class="empty-tip">
      <text>暂无历史记录</text>
    </view>
  </view>

  <!-- 调试配置（可折叠） -->
  <view class="debug-section">
    <view class="debug-toggle" bindtap="toggleDebug">⚙️ 调试配置</view>
    <view class="debug-content" wx:if="{{showDebug}}">
      <input 
        class="input" 
        placeholder="baseURL" 
        value="{{baseURL}}" 
        bindinput="onBaseURLInput" 
      />
      <input 
        class="input" 
        placeholder="Bearer Token" 
        value="{{token}}" 
        bindinput="onTokenInput" 
      />
      <button class="btn secondary" size="mini" bindtap="saveConfig">保存</button>
    </view>
  </view>
</view>

<!-- 分享弹窗 -->
<view class="modal-mask" wx:if="{{showShareModal}}" bindtap="closeShareModal"></view>
<view class="modal" wx:if="{{showShareModal}}">
  <view class="modal-title">分享购物清单</view>
  <view class="modal-content">
    <view class="invite-code-box">
      <text class="label">邀请码</text>
      <text class="code">{{inviteCode}}</text>
      <button class="btn-copy" bindtap="copyInviteCode">复制</button>
    </view>
    <view class="divider-text">或</view>
    <button class="btn-wechat-share" open-type="share">发送给微信好友</button>
  </view>
  <button class="modal-close" bindtap="closeShareModal">关闭</button>
</view>
