<view class="page">
  <view class="hero-card">
    <text class="hero-kicker">SHOPPING FLOW</text>
    <text class="hero-title">把推荐、计划和采购单收拢到一处</text>
    <text class="hero-desc">
      {{listMode === 'server' ? '当前是云端清单，可直接同步到后端并生成分享邀请码。' : '当前是本地兜底模式，登录后会自动切换到云端清单。'}}
    </text>

    <view class="hero-flags">
      <text class="hero-flag">{{listMode === 'server' ? '云端清单' : '本地清单'}}</text>
      <text class="hero-flag soft">{{activeListDate || '尚未同步日期'}}</text>
    </view>

    <view class="hero-stats">
      <view class="stat-pill">
        <text class="stat-value">{{stats.unchecked}}</text>
        <text class="stat-label">待买</text>
      </view>
      <view class="stat-pill">
        <text class="stat-value">{{stats.checked}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-pill">
        <text class="stat-value">{{stats.total}}</text>
        <text class="stat-label">总项目</text>
      </view>
    </view>

    <entitlement-banner wx:if="{{planBanner.title}}"
      title="{{planBanner.title}}"
      subtitle="{{planBanner.subtitle}}"
      badge-text="{{planBanner.badgeText}}"
      action-text="{{planBanner.actionText}}"
      footer-text="{{planBanner.footerText}}"
      quota-cards="{{planBanner.quotaCards}}"
      theme="{{planBanner.theme}}"
      bindactiontap="goToMembership"
    />
  </view>

  <view class="feedback-banner feedback-banner-{{actionFeedback.tone}}" wx:if="{{actionFeedback}}">
    <text>{{actionFeedback.message}}</text>
  </view>

  <view class="member-hint-card {{weeklyPlanQuotaCard ? 'active' : ''}}">
    <view class="member-hint-main">
      <text class="member-hint-title">{{weeklyPlanQuotaCard ? '本周计划能力已可用' : '开通后周计划会更顺手'}}</text>
      <text class="member-hint-desc">
        {{weeklyPlanQuotaCard ? '支持自然语言生成、查看剩余次数，并在小程序里继续补清单。' : '会员可用自然语言周计划、智能推荐和跨端同步。'}}
      </text>
    </view>
    <view class="member-hint-btn" bindtap="goToMembership">{{weeklyPlanQuotaCard ? '看权益' : '去开通'}}</view>
  </view>

  <view class="member-quota-row" wx:if="{{weeklyPlanQuotaCard || smartRecommendationQuotaCard}}">
    <view class="member-quota-pill" wx:if="{{weeklyPlanQuotaCard}}">
      <text class="member-quota-value">{{weeklyPlanQuotaCard.value}}</text>
      <text class="member-quota-title">周计划剩余</text>
    </view>
    <view class="member-quota-pill" wx:if="{{smartRecommendationQuotaCard}}">
      <text class="member-quota-value">{{smartRecommendationQuotaCard.value}}</text>
      <text class="member-quota-title">智能推荐剩余</text>
    </view>
  </view>

  <view class="tab-bar">
    <view class="tab {{activeTab === 'current' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="current">当前清单</view>
    <view class="tab {{activeTab === 'generate' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="generate">智能生成</view>
    <view class="tab {{activeTab === 'history' ? 'active' : ''}}" bindtap="onTabSwitch" data-tab="history">历史记录</view>
  </view>

  <view wx:if="{{activeTab === 'current'}}">
    <view class="summary-card" wx:if="{{shoppingSummary}}">
      <view class="summary-top">
        <view class="summary-badge">库存覆盖 {{shoppingSummary.covered_count || 0}}</view>
        <view class="summary-badge accent">仍需采购 {{shoppingSummary.missing_count || 0}}</view>
      </view>
      <text class="summary-title">清单与库存联动结果</text>
      <text class="summary-desc">
        {{shoppingSummary.expiring_items.length ? ('有 ' + shoppingSummary.expiring_items.length + ' 项临期食材可优先消耗。') : '当前没有临期食材提醒。'}}
      </text>
      <view class="summary-list" wx:if="{{shoppingSummary.missing_items.length}}">
        <block wx:for="{{shoppingSummary.missing_items}}" wx:key="index">
          <view class="summary-item">缺口：{{item.name}} {{item.missing_amount || item.required_amount}}</view>
        </block>
      </view>
    </view>

    <view class="add-card">
      <view class="section-head">
        <view>
          <text class="section-title">快速加一项</text>
          <text class="section-subtitle">支持本地兜底，也支持云端清单直接编辑。</text>
        </view>
      </view>
      <view class="add-row">
        <input
          class="add-input"
          placeholder="例如：鸡蛋、南瓜、无糖酸奶"
          value="{{newItem}}"
          bindinput="onNewItemInput"
        />
        <view class="add-btn" bindtap="addItem">添加</view>
      </view>
    </view>

    <view class="list-card">
      <view class="section-head">
        <view>
          <text class="section-title">采购清单</text>
          <text class="section-subtitle">共 {{stats.total}} 项，待买 {{stats.unchecked}} 项。</text>
        </view>
        <text class="section-link" bindtap="clearChecked">清理已购</text>
      </view>

      <view class="loading-block" wx:if="{{loading}}">
        <view class="spinner"></view>
        <text>正在同步清单...</text>
      </view>

      <block wx:for="{{items}}" wx:key="index">
        <view class="shopping-item {{item.checked ? 'checked' : ''}}">
          <view class="check-indicator {{item.checked ? 'active' : ''}}" bindtap="toggleItem" data-index="{{index}}">
            <van-icon wx:if="{{item.checked}}" name="success" size="16" color="#ffffff" />
          </view>
          <view class="shopping-body" bindtap="toggleItem" data-index="{{index}}">
            <text class="shopping-name">{{item.name}}</text>
            <view class="shopping-meta">
              <text wx:if="{{item.quantity}}">{{item.quantity}}{{item.unit}}</text>
              <text wx:if="{{item.sourceMealType}}">{{item.sourceMealType}}</text>
              <text class="mode-tag">{{item.source === 'server' ? '云端' : '本地'}}</text>
            </view>
          </view>
          <view class="delete-btn" bindtap="deleteItem" data-index="{{index}}">
            <van-icon name="delete-o" size="18" color="#c65a45" />
          </view>
        </view>
      </block>

      <view class="empty-card" wx:if="{{!loading && !items.length}}">
        <text class="empty-title">当前还没有采购项</text>
        <text class="empty-desc">从推荐页或菜谱详情页加入食材后，会自动出现在这里。</text>
      </view>
    </view>

    <view class="share-bar">
      <view class="share-btn" bindtap="onShare">生成分享邀请码</view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'history'}}" class="history-card">
    <view class="section-head">
      <view>
        <text class="section-title">最近完成过的采购</text>
        <text class="section-subtitle">按每次清理已购项目自动归档。</text>
      </view>
    </view>

    <block wx:for="{{history}}" wx:key="index">
      <view class="history-item">
        <text class="history-date">{{item.date}}</text>
        <view class="history-tags">
          <block wx:for="{{item.items}}" wx:for-item="historyItem" wx:key="index">
            <text class="history-tag">{{historyItem.name}}</text>
          </block>
        </view>
      </view>
    </block>

    <view class="empty-card" wx:if="{{!history.length}}">
      <text class="empty-title">还没有历史记录</text>
      <text class="empty-desc">清理已购项目后，这里会自动归档本次采购结果。</text>
    </view>
  </view>

  <view wx:if="{{activeTab === 'generate'}}" class="generate-card">
    <view class="section-head">
      <view>
        <text class="section-title">本周计划面板</text>
        <text class="section-subtitle">生成后会稳定展示整周安排，并保留到下次进入页面。</text>
      </view>
    </view>

    <view class="preference-box">
      <text>{{planPreferenceSummary || '生成时会优先参考宝宝月龄、做饭时长和忌口。'}}</text>
    </view>

    <view class="quota-inline-card" wx:if="{{weeklyPlanQuotaCard}}">
      <text class="quota-inline-title">本期自然语言周计划</text>
      <text class="quota-inline-value">{{weeklyPlanQuotaCard.value}}</text>
      <text class="quota-inline-desc">{{weeklyPlanQuotaCard.desc}}</text>
    </view>

    <view class="generate-guide-row">
      <view class="guide-card" bindtap="goToMembership">
        <text class="guide-card-title">会员说明</text>
        <text class="guide-card-desc">查看剩余次数和跨端权益</text>
      </view>
      <view class="guide-card light" bindtap="goToRecipe">
        <text class="guide-card-title">去找菜谱</text>
        <text class="guide-card-desc">先看菜，再回来生成周计划</text>
      </view>
    </view>

    <view class="mode-switch">
      <view class="mode-chip {{isSmartMode ? 'active' : ''}}" bindtap="toggleSmartMode">智能描述</view>
      <view class="mode-chip {{!isSmartMode ? 'active' : ''}}" bindtap="toggleSmartMode">标准选项</view>
    </view>

    <view wx:if="{{isSmartMode}}">
      <textarea
        class="prompt-input"
        placeholder="例如：这周多做鱼类，宝宝挑食，不吃胡萝卜，30 分钟内完成。"
        value="{{smartPrompt}}"
        bindinput="onSmartPromptInput"
        maxlength="500"
      ></textarea>
    </view>

    <view wx:else>
      <view class="option-group">
        <text class="option-title">宝宝月龄</text>
        <view class="option-list">
          <view class="option-chip {{babyAge === null ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="">不限</view>
          <view class="option-chip {{babyAge === 6 ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="{{6}}">6 个月</view>
          <view class="option-chip {{babyAge === 8 ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="{{8}}">8 个月</view>
          <view class="option-chip {{babyAge === 10 ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="{{10}}">10 个月</view>
          <view class="option-chip {{babyAge === 12 ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="{{12}}">12 个月</view>
          <view class="option-chip {{babyAge === 18 ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="{{18}}">18 个月</view>
          <view class="option-chip {{babyAge === 24 ? 'active' : ''}}" bindtap="onBabyAgeSelect" data-age="{{24}}">24 个月</view>
        </view>
      </view>

      <view class="option-group">
        <text class="option-title">排除食材</text>
        <input class="exclude-input" placeholder="例如：虾、花生、牛奶" value="{{excludeIngredients}}" bindinput="onExcludeInput" />
      </view>
    </view>

    <view class="generate-btn" bindtap="generateMealPlan">
      {{isGenerating ? '正在生成周计划...' : '生成一版周计划'}}
    </view>

    <view class="list-card" wx:if="{{todayExecutionEntries.length}}">
      <view class="section-head">
        <view>
          <text class="section-title">今天执行</text>
          <text class="section-subtitle">与本周计划共用同一份状态，完成情况会同步更新。</text>
        </view>
      </view>
      <block wx:for="{{todayExecutionEntries}}" wx:key="mealType">
        <view class="shopping-item {{item.done ? 'checked' : ''}}">
          <view class="check-indicator {{item.done ? 'active' : ''}}" bindtap="toggleWeeklyMealDone" data-date="{{item.date}}" data-meal-type="{{item.mealType}}">
            <van-icon wx:if="{{item.done}}" name="success" size="16" color="#ffffff" />
          </view>
          <view class="shopping-body">
            <text class="shopping-name">{{item.mealLabel}} · {{item.title}}</text>
            <view class="shopping-meta">
              <text wx:if="{{item.recipeId}}">菜谱已关联</text>
              <text class="mode-tag">{{item.done ? '已完成' : '待执行'}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="weekly-panel-empty empty-card" wx:if="{{!weeklyPlanDays.length}}">
      <text class="empty-title">还没有本周计划</text>
      <text class="empty-desc">先生成一版周计划，早餐、午餐、晚餐会稳定显示在这里。</text>
    </view>

    <view class="weekly-panel" wx:if="{{weeklyPlanDays.length}}">
      <view class="generated-tags" wx:if="{{generatedPlanSummaryTags.length}}">
        <block wx:for="{{generatedPlanSummaryTags}}" wx:key="*this">
          <text class="generated-tag">{{item}}</text>
        </block>
      </view>
      <view class="weekly-day-list">
        <block wx:for="{{weeklyPlanDays}}" wx:key="date" wx:for-item="dayItem">
          <view class="weekly-day-card">
            <text class="weekly-day-title">{{dayItem.label}}</text>
            <block wx:for="{{dayItem.meals}}" wx:key="mealType" wx:for-item="mealItem">
              <view class="weekly-meal-row">
                <view class="weekly-meal-main">
                  <text class="weekly-meal-type">{{mealItem.mealLabel}}</text>
                  <text class="weekly-meal-name {{mealItem.title ? '' : 'is-empty'}}">{{mealItem.title || '暂未安排'}}</text>
                </view>
                <view class="weekly-meal-actions" wx:if="{{mealItem.title}}">
                  <text class="weekly-action" bindtap="goToRecipe" data-date="{{dayItem.date}}" data-meal-type="{{mealItem.mealType}}">看菜谱</text>
                  <text class="weekly-action" bindtap="addWeeklyMealToShopping" data-date="{{dayItem.date}}" data-meal-type="{{mealItem.mealType}}">加采购</text>
                  <text class="weekly-action" bindtap="toggleWeeklyMealDone" data-date="{{dayItem.date}}" data-meal-type="{{mealItem.mealType}}">{{mealItem.done ? '取消完成' : '标记完成'}}</text>
                </view>
              </view>
            </block>
          </view>
        </block>
      </view>
      <view class="generated-link" wx:if="{{generatedMealPlan}}" bindtap="viewGeneratedPlan">查看完整概览</view>
    </view>
  </view>

  <view class="debug-card">
    <view class="debug-toggle" bindtap="toggleDebug">调试配置</view>
    <view wx:if="{{showDebug}}" class="debug-body">
      <input class="debug-input" placeholder="baseURL" value="{{baseURL}}" bindinput="onBaseURLInput" />
      <input class="debug-input" placeholder="Bearer Token" value="{{token}}" bindinput="onTokenInput" />
      <view class="debug-btn" bindtap="saveConfig">保存配置</view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showShareModal}}" bindtap="closeShareModal"></view>
<view class="share-modal" wx:if="{{showShareModal}}">
  <text class="share-modal-title">分享采购清单</text>
  <view class="share-code-box">
    <text class="share-code-label">邀请码</text>
    <text class="share-code">{{inviteCode}}</text>
    <text class="share-link" wx:if="{{shareLink}}">{{shareLink}}</text>
  </view>
  <view class="share-modal-btn primary" bindtap="copyInviteCode">复制邀请码</view>
  <button class="share-modal-btn secondary" open-type="share">直接转发给家人</button>
  <view class="share-modal-close" bindtap="closeShareModal">关闭</view>
</view>
