<view class="container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view 
      class="tab {{activeTab === 'current' ? 'active' : ''}}" 
      bindtap="onTabSwitch" 
      data-tab="current">
      当前清单
    </view>
    <view 
      class="tab {{activeTab === 'generate' ? 'active' : ''}}" 
      bindtap="onTabSwitch" 
      data-tab="generate">
      ✨ 智能生成
    </view>
    <view 
      class="tab {{activeTab === 'history' ? 'active' : ''}}" 
      bindtap="onTabSwitch" 
      data-tab="history">
      历史清单
    </view>
  </view>

  <!-- 当前清单 -->
  <view wx:if="{{activeTab === 'current'}}">
    <!-- 添加区域 -->
    <view class="add-section">
      <van-field
        value="{{ newItem }}"
        placeholder="添加食材..."
        bind:input="onNewItemInput"
        border="{{ false }}"
        clearable
      />
      <van-button type="primary" size="small" round bind:click="addItem">添加</van-button>
    </view>

    <!-- 清单列表 -->
    <view class="list-header">
      <text>清单 ({{items.length}})</text>
      <text class="clear-btn" bindtap="clearChecked">清除已购</text>
    </view>

    <view wx:if="{{shoppingSummary}}" class="summary-card">
      <view class="summary-row">
        <text>库存覆盖 {{shoppingSummary.covered_count || 0}}</text>
        <text>仍需购买 {{shoppingSummary.missing_count || 0}}</text>
        <text>临期优先 {{shoppingSummary.expiring_items.length || 0}}</text>
      </view>
      <view wx:if="{{shoppingSummary.missing_items.length}}" class="summary-block">
        <text class="summary-title">缺口</text>
        <text wx:for="{{shoppingSummary.missing_items}}" wx:key="index">• {{item.name}} {{item.missing_amount || item.required_amount}}</text>
      </view>
    </view>

    <block wx:for="{{items}}" wx:key="index">
      <view class="list-item">
        <van-checkbox value="{{ item.checked }}" bind:change="toggleItem" data-index="{{index}}"/>
        <view class="item-text {{item.checked ? 'done' : ''}}">
          {{item.name}}
          <text class="item-quantity" wx:if="{{item.quantity}}">{{item.quantity}}{{item.unit}}</text>
        </view>
        <van-icon name="delete-o" bindtap="deleteItem" data-index="{{index}}" color="#ff4d4f"/>
      </view>
    </block>

    <view wx:if="{{!items.length}}" class="empty-tip">
      <text>清单为空，快去添加吧～</text>
    </view>

    <!-- 分享按钮 -->
    <view class="share-section">
      <van-button type="success" size="large" round open-type="share">📤 分享清单给家人</van-button>
    </view>
  </view>

  <!-- 历史清单 -->
  <view wx:if="{{activeTab === 'history'}}">
    <block wx:for="{{history}}" wx:key="index">
      <view class="history-item">
        <view class="history-date">{{item.date}}</view>
        <view class="history-items">
          <text wx:for="{{item.items}}" wx:for-item="i" wx:key="*this">{{i.name}}{{index < item.items.length - 1 ? '、' : ''}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{!history.length}}" class="empty-tip">
      <text>暂无历史记录</text>
    </view>
  </view>

  <!-- 智能生成 -->
  <view wx:if="{{activeTab === 'generate'}}" class="generate-section">
    <view class="generate-header">
      <text class="generate-title">✨ AI 智能生成周计划</text>
      <text class="generate-desc">用自然语言描述您的需求，AI 将为您智能生成一周辅食计划</text>
      <text class="generate-pref" wx:if="{{planPreferenceSummary}}">生成时会优先参考：{{planPreferenceSummary}}</text>
      <text class="generate-pref" wx:else>生成时会优先参考你的月龄、做饭时长和需要避开的食材</text>
    </view>

    <!-- 模式选择 -->
    <view class="mode-selector">
      <view 
        class="mode-option {{isSmartMode ? 'active' : ''}}" 
        bindtap="toggleSmartMode">
        <text>✨ 智能模式</text>
      </view>
      <view 
        class="mode-option {{!isSmartMode ? 'active' : ''}}" 
        bindtap="toggleSmartMode">
        <text>📋 标准模式</text>
      </view>
    </view>

    <!-- 智能模式输入 -->
    <view wx:if="{{isSmartMode}}" class="smart-mode-input">
      <textarea
        class="prompt-input"
        placeholder="例如: 这周多做鱼类的菜，宝宝挑食不喜欢胡萝卜，做饭时间控制在30分钟以内"
        value="{{smartPrompt}}"
        bindinput="onSmartPromptInput"
        maxlength="500"
      ></textarea>
      <text class="input-hint">可以直接说口味、宝宝月龄、时间预算，系统会一起理解</text>
    </view>

    <!-- 标准模式选项 -->
    <view wx:if="{{!isSmartMode}}" class="standard-options">
      <view class="option-group">
        <text class="option-label">宝宝月龄（可选）</text>
        <view class="age-options">
          <view 
            class="age-option {{babyAge === null ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{null}}">
            不限
          </view>
          <view 
            class="age-option {{babyAge === 6 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{6}}">
            6月
          </view>
          <view 
            class="age-option {{babyAge === 8 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{8}}">
            8月
          </view>
          <view 
            class="age-option {{babyAge === 10 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{10}}">
            10月
          </view>
          <view 
            class="age-option {{babyAge === 12 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{12}}">
            12月
          </view>
          <view 
            class="age-option {{babyAge === 18 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{18}}">
            18月
          </view>
          <view 
            class="age-option {{babyAge === 24 ? 'active' : ''}}" 
            bindtap="onBabyAgeSelect" 
            data-age="{{24}}">
            24月
          </view>
        </view>
      </view>

      <view class="option-group">
        <text class="option-label">排除食材（用逗号分隔）</text>
        <input 
          class="exclude-input" 
          placeholder="例如: 虾, 花生, 牛奶" 
          value="{{excludeIngredients}}"
          bindinput="onExcludeInput"
        />
      </view>
    </view>

    <!-- 生成按钮 -->
    <view class="generate-action">
      <van-button 
        type="primary" 
        size="large" 
        round 
        loading="{{isGenerating}}"
        bind:click="generateMealPlan">
        {{isGenerating ? '生成中...' : '生成周计划'}}
      </van-button>
    </view>

    <!-- 生成结果预览 -->
    <view wx:if="{{generatedMealPlan}}" class="result-preview">
      <view class="result-header">
        <text class="result-title">✅ 生成成功</text>
      </view>
      <view class="result-content">
        <text class="result-name">{{generatedMealPlan.title}}</text>
      </view>
      <view class="result-action">
        <van-button type="success" size="small" round bindtap="viewGeneratedPlan">查看详情</van-button>
      </view>
    </view>
  </view>

  <!-- 调试配置（可折叠） -->
  <view class="debug-section">
    <view class="debug-toggle" bindtap="toggleDebug">⚙️ 调试配置</view>
    <view class="debug-content" wx:if="{{showDebug}}">
      <input 
        class="input" 
        placeholder="baseURL" 
        value="{{baseURL}}" 
        bindinput="onBaseURLInput" 
      />
      <input 
        class="input" 
        placeholder="Bearer Token" 
        value="{{token}}" 
        bindinput="onTokenInput" 
      />
      <button class="btn secondary" size="mini" bindtap="saveConfig">保存</button>
    </view>
  </view>
</view>

<!-- 分享弹窗 -->
<view class="modal-mask" wx:if="{{showShareModal}}" bindtap="closeShareModal"></view>
<view class="modal" wx:if="{{showShareModal}}">
  <view class="modal-title">分享购物清单</view>
  <view class="modal-content">
    <view class="invite-code-box">
      <text class="label">邀请码</text>
      <text class="code">{{inviteCode}}</text>
      <button class="btn-copy" bindtap="copyInviteCode">复制</button>
    </view>
    <view class="divider-text">或</view>
    <button class="btn-wechat-share" open-type="share">发送给微信好友</button>
  </view>
  <button class="modal-close" bindtap="closeShareModal">关闭</button>
</view>
