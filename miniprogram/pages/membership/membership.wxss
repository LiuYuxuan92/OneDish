.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(224, 212, 195, 0.46), transparent 34%),
    linear-gradient(180deg, #f8f5ef 0%, #f2f4ef 42%, #eef2ee 100%);
}

.loading-state {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-card,
.quota-section,
.benefits-section,
.faq-section,
.experience-section,
.product-section {
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 40rpx rgba(34, 52, 43, 0.08);
}

.member-card {
  padding: 44rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #274539, #3d5f4e);
  color: #ffffff;
}

.member-card.active {
  background: linear-gradient(135deg, #8d6a40, #b58b5c);
}

.member-icon {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 18rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
}

.member-title {
  font-size: 40rpx;
  font-weight: 700;
}

.member-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: rgba(255, 255, 255, 0.8);
}

.btn-member,
.btn-login,
.share-btn {
  border-radius: 999rpx;
  border: none;
}

.btn-member {
  margin-top: 30rpx;
  padding: 20rpx 54rpx;
  background: #ffffff;
  color: #274539;
  font-size: 30rpx;
  font-weight: 700;
  display: inline-block;
}

.member-card.active .btn-member {
  color: #8d6a40;
}

.member-strip {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.member-strip-item {
  flex: 1;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 30rpx rgba(34, 52, 43, 0.06);
}

.member-strip-value {
  display: block;
  color: #22342b;
  font-size: 28rpx;
  font-weight: 700;
}

.member-strip-label {
  display: block;
  margin-top: 8rpx;
  color: #7a847d;
  font-size: 20rpx;
}

.btn-login {
  margin-top: 16rpx;
  padding: 18rpx 44rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.quota-section,
.benefits-section,
.faq-section,
.experience-section,
.product-section {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.section-title {
  margin-bottom: 22rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #22342b;
}

.quota-grid,
.experience-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.quota-card,
.experience-card,
.product-card,
.benefit-item {
  border-radius: 24rpx;
}

.quota-card {
  padding: 18rpx 16rpx;
  background: linear-gradient(180deg, #f3f5f0 0%, #ecf0ea 100%);
}

.quota-value {
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #274539;
}

.quota-title {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #22342b;
}

.quota-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: #7c8781;
}

.feature-group {
  margin-bottom: 24rpx;
}

.feature-group:last-child {
  margin-bottom: 0;
}

.feature-group-title {
  margin-bottom: 16rpx;
  font-size: 23rpx;
  font-weight: 700;
  color: #738078;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.benefit-item {
  padding: 20rpx;
  background: #f4f6f2;
}

.benefit-item.vip {
  background: linear-gradient(135deg, #f8f4ed 0%, #f2ece2 100%);
}

.benefit-item.upsell {
  background: linear-gradient(180deg, #f7f3eb 0%, #f1ece1 100%);
}

.benefit-main {
  display: flex;
  flex-direction: column;
}

.benefit-title-row,
.product-top,
.product-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.benefit-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #22342b;
}

.benefit-desc,
.benefit-extra,
.product-subtitle,
.product-desc,
.experience-desc,
.dev-desc,
.faq-a,
.order-desc {
  line-height: 1.65;
  color: #748179;
}

.benefit-desc,
.order-desc {
  font-size: 22rpx;
}

.benefit-extra,
.product-subtitle,
.product-desc,
.experience-desc,
.dev-desc,
.faq-a {
  font-size: 21rpx;
}

.benefit-extra {
  margin-top: 10rpx;
}

.benefit-tag,
.product-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e5ece7;
  color: #486154;
  font-size: 20rpx;
  font-weight: 700;
}

.benefit-tag.upsell,
.product-badge {
  background: #efe6d8;
  color: #8a673f;
}

.order-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(34, 52, 43, 0.06);
}

.order-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.order-title,
.faq-q,
.experience-title,
.product-title {
  color: #22342b;
  font-weight: 700;
}

.order-title,
.faq-q,
.product-title {
  font-size: 26rpx;
}

.faq-item {
  margin-bottom: 18rpx;
}

.faq-item:last-child {
  margin-bottom: 0;
}

.experience-card {
  padding: 22rpx 18rpx;
  background: #f4f6f2;
}

.experience-card.warm {
  background: linear-gradient(135deg, #f8f2e8, #f0e8dc);
}

.experience-card.light {
  background: linear-gradient(135deg, #eff3ef, #e7eee8);
}

.experience-title {
  font-size: 24rpx;
}

.experience-desc {
  margin-top: 10rpx;
}

.product-card {
  padding: 22rpx;
  background: #f6f7f3;
  border: 1rpx solid rgba(39, 69, 57, 0.06);
  margin-bottom: 14rpx;
}

.product-card:last-child {
  margin-bottom: 0;
}

.product-card.active {
  background: linear-gradient(135deg, #f7f1e8, #efe8dc);
  border-color: rgba(141, 106, 64, 0.16);
}

.product-top {
  align-items: flex-start;
}

.product-title-row {
  justify-content: flex-start;
  gap: 10rpx;
}

.product-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #22342b;
}

.product-highlight-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.product-highlight {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #607068;
  font-size: 20rpx;
}

.dev-section {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(34, 52, 43, 0.08);
}

.dev-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.dev-btn {
  flex: 1;
  min-width: 260rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #486154;
  background: #f4f6f2;
  border: 1rpx solid rgba(39, 69, 57, 0.08);
}

.dev-btn.primary {
  background: #274539;
  color: #ffffff;
  border-color: #274539;
}

.dev-btn.danger {
  margin-top: 14rpx;
  background: #f7eee9;
  color: #b1644f;
  border-color: rgba(177, 100, 79, 0.12);
}

.dev-btn.full {
  width: 100%;
}

.share-section {
  padding: 8rpx 0 20rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.share-btn::after,
.btn-member::after,
.btn-login::after,
.dev-btn::after {
  border: none;
}
