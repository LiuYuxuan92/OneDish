.container {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
}

/* Member Card */
.member-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 32rpx;
}

.member-card.active {
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
}

.member-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.member-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.member-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 32rpx;
}

.btn-member {
  background: #fff;
  color: #667eea;
  border-radius: 44rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: inline-block;
}

.member-card.active .btn-member {
  background: #fff;
  color: #fda085;
}

/* Benefits Section */
.benefits-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.benefits-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.benefit-item {
  background: #f5f7fb;
  border-radius: 12rpx;
  padding: 20rpx;
  position: relative;
  overflow: hidden;
}

.benefit-item.vip {
  background: linear-gradient(135deg, #fef3e2 0%, #fde8d0 100%);
}

.benefit-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.benefit-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.benefit-desc {
  font-size: 22rpx;
  color: #999;
}

.benefit-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #f5a623;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
}

/* FAQ Section */
.faq-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.faq-item {
  margin-bottom: 20rpx;
}

.faq-item:last-child {
  margin-bottom: 0;
}

.faq-q {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.faq-a {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* Share Section */
.share-section {
  padding: 24rpx 0;
}

.btn-share {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx;
  font-size: 30rpx;
}
