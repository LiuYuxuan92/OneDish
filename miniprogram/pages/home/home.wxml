<view class="page">
  <view class="hero-panel">
    <view class="hero-topbar">
      <view class="hero-pill" bindtap="goToSearch">
        <van-icon name="search" size="14" color="#234033" />
        <text>搜索菜谱</text>
      </view>
      <view class="hero-avatar" bindtap="goToProfile">
        <van-icon name="user-o" size="18" color="#ffffff" />
      </view>
    </view>

    <view class="hero-cover-card" wx:if="{{homeHeroCover}}">
      <image class="hero-cover-image" src="{{homeHeroCover}}" mode="aspectFill" lazy-load="true" />
      <view class="hero-cover-overlay">
        <text class="hero-cover-badge">ONE DISH · TWO WAYS</text>
        <text class="hero-cover-title">一锅备菜，先顾全家，再顺手照顾宝宝。</text>
        <text class="hero-cover-desc">把“今天吃什么”变成一眼就能做决定的首页首屏。</text>
      </view>
    </view>

    <view class="hero-copy">
      <text class="hero-kicker">TODAY'S PICK</text>
      <text class="hero-title">今天先给你一份更稳妥的晚餐建议</text>
      <text class="hero-desc">推荐会优先参考宝宝月龄、口味偏好和下厨时间，把更适合你家的方案放到前面。</text>
    </view>

    <view class="hero-metrics">
      <view class="hero-metric" wx:if="{{preferenceSummaryText}}">
        <text class="hero-metric-label">PREFERENCE</text>
        <text class="hero-metric-value">{{preferenceSummaryText}}</text>
      </view>
      <view class="hero-metric">
        <text class="hero-metric-label">{{memberSummary.isMember ? 'MEMBER' : 'STATUS'}}</text>
        <text class="hero-metric-value">{{memberSummary.isMember ? '已开通成长会员' : '可升级成长会员'}}</text>
      </view>
    </view>
  </view>

  <view class="feedback-banner feedback-banner-{{actionFeedback.tone}}" wx:if="{{actionFeedback}}">
    <text>{{actionFeedback.message}}</text>
  </view>

  <entitlement-banner wx:if="{{membershipBanner.title}}"
    title="{{membershipBanner.title}}"
    subtitle="{{membershipBanner.subtitle}}"
    badge-text="{{membershipBanner.badgeText}}"
    action-text="{{membershipBanner.actionText}}"
    footer-text="{{membershipBanner.footerText}}"
    quota-cards="{{membershipBanner.quotaCards}}"
    theme="{{membershipBanner.theme}}"
    bindactiontap="goToMembership"
  />

  <view class="shortcut-grid">
    <view class="shortcut-card" bindtap="goToPlan">
      <text class="shortcut-title">AI 周计划</text>
      <text class="shortcut-desc">先排一周，再去采购。</text>
    </view>
    <view class="shortcut-card warm" bindtap="goToBabyRewrite">
      <text class="shortcut-title">宝宝改写</text>
      <text class="shortcut-desc">从当前推荐直接进入。</text>
    </view>
    <view class="shortcut-card light" bindtap="goRecipe">
      <text class="shortcut-title">逛菜谱库</text>
      <text class="shortcut-desc">不想等推荐就直接挑。</text>
    </view>
    <view class="shortcut-card soft" bindtap="goToFavorites">
      <text class="shortcut-title">我的收藏</text>
      <text class="shortcut-desc">把反复做的菜集中收好。</text>
    </view>
  </view>

  <view class="state-card" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text class="state-title">正在生成今日推荐</text>
    <text class="state-desc">会优先结合偏好配置和近期推荐结果。</text>
  </view>

  <view class="state-card error" wx:elif="{{error}}">
    <text class="state-title">{{error}}</text>
    <text class="state-desc">可以重新拉取推荐，或者直接去菜谱页浏览。</text>
    <view class="state-actions">
      <view class="outline-btn" bindtap="loadTodayRecommendation">重新加载</view>
      <view class="solid-btn" bindtap="goRecipe">浏览菜谱</view>
    </view>
  </view>

  <view class="state-card" wx:elif="{{!recommendation}}">
    <text class="state-title">今天还没有推荐菜谱</text>
    <text class="state-desc">先去菜谱库看看，或者稍后再刷新一次。</text>
    <view class="solid-btn" bindtap="goRecipe">打开菜谱库</view>
  </view>

  <view wx:else>
    <view class="version-switch" wx:if="{{recommendation.baby_version}}">
      <view
        class="version-tab {{currentVersion === 'adult' ? 'active' : ''}}"
        bindtap="switchVersion"
        data-version="adult"
      >
        成人版
      </view>
      <view
        class="version-tab {{currentVersion === 'baby' ? 'active' : ''}}"
        bindtap="switchVersion"
        data-version="baby"
      >
        宝宝版
      </view>
    </view>

    <view class="recipe-card">
      <view class="recipe-media" bindtap="goRecipe">
        <image
          wx:if="{{currentVersion === 'baby' && recommendation.baby_version ? recommendation.baby_version.cover_url : recommendation.cover_url}}"
          class="recipe-cover"
          src="{{currentVersion === 'baby' && recommendation.baby_version ? recommendation.baby_version.cover_url : recommendation.cover_url}}"
          mode="aspectFill"
          lazy-load="true"
        />
        <view wx:else class="recipe-cover recipe-cover-fallback">
          <text class="recipe-cover-kicker">TODAY'S MENU</text>
          <view class="recipe-cover-placeholder">
            <view class="recipe-cover-plate"></view>
            <view class="recipe-cover-placeholder-copy">
              <text class="recipe-cover-placeholder-title">暂无菜谱图</text>
              <text class="recipe-cover-placeholder-desc">
                先看下面的做法重点、时长和推荐理由。
              </text>
            </view>
          </view>
          <view class="recipe-cover-orb"></view>
        </view>
      </view>

      <view class="recipe-body">
        <view class="recipe-head">
          <view class="recipe-title-wrap">
            <text class="recipe-title">
              {{currentVersion === 'baby' && recommendation.baby_version ? recommendation.baby_version.title : recommendation.title}}
            </text>
            <text class="recipe-subtitle" wx:if="{{currentVersion === 'baby' && recommendation.baby_version && recommendation.baby_version.age_range}}">
              适合 {{recommendation.baby_version.age_range}}
            </text>
          </view>
          <view class="favorite-chip {{isFavorited ? 'active' : ''}}" bindtap="onFavorite">
            <van-icon name="{{isFavorited ? 'like' : 'like-o'}}" size="14" color="{{isFavorited ? '#ffffff' : '#b85b34'}}" />
            <text>{{isFavorited ? '已收藏' : '收藏'}}</text>
          </view>
        </view>

        <view class="meta-row">
          <view class="meta-tag" wx:if="{{recommendation.difficulty}}">{{recommendation.difficulty}}</view>
          <view class="meta-tag" wx:if="{{recommendation.cook_time}}">{{recommendation.cook_time}} 分钟</view>
          <view class="meta-tag warm" wx:if="{{recommendation.calories}}">{{recommendation.calories}} 千卡</view>
        </view>

        <text class="recipe-desc" wx:if="{{currentVersion === 'baby' && recommendation.baby_version ? recommendation.baby_version.description : recommendation.description}}">
          {{currentVersion === 'baby' && recommendation.baby_version ? recommendation.baby_version.description : recommendation.description}}
        </text>

        <view class="feedback-recap feedback-recap-{{recommendationFeedbackSummary.state}}" wx:if="{{recommendationFeedbackSummary}}">
          <text class="feedback-recap-label">{{recommendationFeedbackSummary.label}}</text>
        </view>

        <view class="reason-card" wx:if="{{recommendationReasons.length}}">
          <text class="reason-title">为什么今天推荐这道菜</text>
          <block wx:for="{{recommendationReasons}}" wx:key="*this">
            <view class="reason-item">
              <view class="reason-dot"></view>
              <text>{{item}}</text>
            </view>
          </block>
          <text class="reason-foot" wx:if="{{currentVersion === 'baby' && recommendation.baby_version && recommendation.baby_version.tips}}">
            喂养提示：{{recommendation.baby_version.tips}}
          </text>
        </view>
      </view>
    </view>

    <view class="action-grid">
      <view class="primary-action" bindtap="onSwap">
        <text class="action-title">{{swapping ? '正在重新计算推荐' : '换一份更合适的'}}</text>
        <text class="action-desc">保留今天的偏好条件，重新找一份更匹配的方案。</text>
      </view>

      <view class="secondary-actions">
        <view class="action-card fresh" bindtap="addToShoppingList">
          <text class="action-card-title">加入清单</text>
          <text class="action-card-desc">登录后写入云端采购单，未登录先放本地。</text>
        </view>
        <button class="action-card share" open-type="share">
          <text class="action-card-title">分享推荐</text>
          <text class="action-card-desc">直接转给家人，一起确认今晚吃什么。</text>
        </button>
      </view>
    </view>
  </view>
</view>
