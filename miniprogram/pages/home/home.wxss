.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(247, 205, 157, 0.46), transparent 34%),
    radial-gradient(circle at top left, rgba(204, 226, 213, 0.22), transparent 24%),
    linear-gradient(180deg, #fbf3e8 0%, #f4f6f0 36%, #eef3ef 100%);
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.hero-panel {
  padding: 8rpx 0 18rpx;
}

.hero-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 245, 0.94);
  color: #234033;
  font-size: 24rpx;
  border: 1rpx solid rgba(39, 69, 57, 0.06);
  box-shadow: 0 10rpx 24rpx rgba(100, 70, 34, 0.06);
}

.hero-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #355f4e, #234033);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 22rpx rgba(28, 49, 39, 0.24);
}

.hero-cover-card {
  position: relative;
  margin-top: 24rpx;
  border-radius: 34rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 18rpx 40rpx rgba(31, 47, 37, 0.08);
}

.hero-cover-image {
  width: 100%;
  height: 360rpx;
  display: block;
}

.hero-cover-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 26rpx 28rpx 28rpx;
  background: linear-gradient(180deg, rgba(20, 30, 24, 0.02), rgba(20, 30, 24, 0.58));
}

.hero-cover-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.hero-cover-title {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #ffffff;
}

.hero-cover-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.58;
  color: rgba(255, 255, 255, 0.9);
}

.hero-copy {
  margin-top: 28rpx;
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 221, 186, 0.9), transparent 34%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(255, 249, 243, 0.98));
  box-shadow: 0 18rpx 40rpx rgba(31, 47, 37, 0.08);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(53, 95, 78, 0.12);
  color: #28473a;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 50rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #1f2f25;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5f6d65;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.hero-metric {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(39, 69, 57, 0.06);
  box-shadow: 0 10rpx 24rpx rgba(31, 47, 37, 0.04);
}

.hero-metric-label {
  display: block;
  color: #7a867f;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.hero-metric-value {
  display: block;
  margin-top: 10rpx;
  color: #23342b;
  font-size: 24rpx;
  line-height: 1.58;
  font-weight: 600;
}

.feedback-banner {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 30rpx rgba(31, 47, 37, 0.08);
}

.feedback-banner text {
  display: block;
  font-size: 24rpx;
  line-height: 1.62;
}

.feedback-banner-success {
  background: linear-gradient(135deg, #e9f7ef, #f8fcfa);
  color: #27563f;
}

.feedback-banner-info {
  background: linear-gradient(135deg, #eef4ff, #fbfcff);
  color: #3558a3;
}

.state-card,
.recipe-card,
.action-grid {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 16rpx 40rpx rgba(31, 47, 37, 0.08);
}

.state-card {
  padding: 60rpx 38rpx;
  text-align: center;
}

.state-card.error {
  background: rgba(255, 248, 247, 0.96);
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  margin: 0 auto 20rpx;
  border: 4rpx solid rgba(34, 64, 51, 0.12);
  border-top-color: #355f4e;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.state-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #24342b;
}

.state-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #768079;
}

.state-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-top: 28rpx;
}

.solid-btn,
.outline-btn {
  min-width: 180rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.solid-btn {
  background: linear-gradient(135deg, #355f4e, #1f342a);
  color: #ffffff;
}

.outline-btn {
  border: 2rpx solid rgba(53, 95, 78, 0.16);
  color: #355f4e;
}

.version-switch {
  display: flex;
  padding: 8rpx;
  margin-bottom: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(39, 69, 57, 0.06);
}

.version-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 20rpx;
  color: #6a766f;
  font-size: 26rpx;
}

.version-tab.active {
  background: #274539;
  color: #ffffff;
  font-weight: 600;
}

.recipe-card {
  overflow: hidden;
}

.recipe-media {
  padding: 18rpx 18rpx 0;
}

.recipe-cover {
  width: 100%;
  height: 332rpx;
  border-radius: 26rpx;
  background: #e8ece9;
}

.recipe-cover-fallback {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 28rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 219, 176, 0.72), transparent 34%),
    linear-gradient(145deg, #f7f7f2, #eaf1ec);
}

.recipe-cover-kicker {
  position: relative;
  z-index: 1;
  color: #687887;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.recipe-cover-placeholder {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 1;
  width: 100%;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
  margin-top: 18rpx;
}

.recipe-cover-plate {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 36% 36%, rgba(255, 255, 255, 0.98), rgba(247, 234, 214, 0.92) 56%, rgba(229, 214, 190, 0.95) 100%);
  box-shadow:
    inset 0 0 0 12rpx rgba(255, 255, 255, 0.58),
    0 20rpx 40rpx rgba(126, 98, 58, 0.14);
  flex-shrink: 0;
}

.recipe-cover-placeholder-copy {
  flex: 1;
  max-width: 290rpx;
}

.recipe-cover-placeholder-title {
  display: block;
  color: #22342b;
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 700;
}

.recipe-cover-placeholder-desc {
  display: block;
  margin-top: 12rpx;
  color: #6f7b75;
  font-size: 24rpx;
  line-height: 1.62;
}

.recipe-cover-orb {
  position: absolute;
  top: 22rpx;
  right: 24rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.46);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.22);
}

.recipe-body {
  padding: 28rpx 28rpx 32rpx;
}

.recipe-head {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.recipe-title-wrap {
  flex: 1;
}

.recipe-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #22342b;
}

.recipe-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8b6130;
}

.favorite-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #fff5ee;
  color: #b85b34;
  font-size: 22rpx;
  border: 1rpx solid rgba(184, 91, 52, 0.1);
}

.favorite-chip.active {
  background: linear-gradient(135deg, #e86d3f, #c95433);
  color: #ffffff;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #355f4e;
  font-size: 22rpx;
}

.meta-tag.warm {
  background: #fff3e7;
  color: #b86827;
}

.recipe-desc {
  display: block;
  margin-top: 22rpx;
  font-size: 26rpx;
  line-height: 1.78;
  color: #58645c;
}

.reason-card {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fcf4e8, #f9efe3);
}

.reason-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #8a5c2d;
}

.feedback-recap {
  margin-top: 18rpx;
}

.feedback-recap-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #5f4326;
}

.reason-item {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  color: #78542e;
  font-size: 24rpx;
  line-height: 1.6;
}

.reason-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #d48f44;
  flex-shrink: 0;
}

.reason-foot {
  display: block;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(120, 84, 46, 0.12);
  font-size: 22rpx;
  line-height: 1.6;
  color: #9a6b39;
}

.action-grid {
  margin-top: 22rpx;
  padding: 22rpx;
}

.primary-action {
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #234033, #345846);
  color: #ffffff;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.action-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  text-align: left;
  box-sizing: border-box;
}

.action-card::after {
  border: none;
}

.action-card.fresh {
  background: #edf6ef;
}

.action-card.share {
  background: #fff4e9;
}

.action-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #24342b;
}

.action-card-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6a756e;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.shortcut-card {
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 14rpx 30rpx rgba(34, 48, 41, 0.08);
}

.shortcut-card.warm {
  background: linear-gradient(135deg, #fff8ef, #fff1df);
}

.shortcut-card.light {
  background: linear-gradient(135deg, #f3f9f6, #eef8f1);
}

.shortcut-card.soft {
  background: linear-gradient(135deg, #f7f4ef, #eef2ec);
}

.shortcut-title {
  display: block;
  color: #24342d;
  font-size: 25rpx;
  font-weight: 700;
}

.shortcut-desc {
  display: block;
  margin-top: 10rpx;
  color: #74827b;
  font-size: 21rpx;
  line-height: 1.6;
}
