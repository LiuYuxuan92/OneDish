.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(250, 206, 166, 0.5), transparent 34%),
    linear-gradient(180deg, #fbf0df 0%, #f5f7fb 36%, #f5f7fb 100%);
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.hero-panel {
  padding: 12rpx 0 28rpx;
}

.hero-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 238, 0.92);
  color: #234033;
  font-size: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(100, 70, 34, 0.08);
}

.hero-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #355f4e, #1e342a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 22rpx rgba(28, 49, 39, 0.24);
}

.hero-copy {
  margin-top: 28rpx;
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(53, 95, 78, 0.12);
  color: #28473a;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #1f2f25;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5c645f;
}

.hero-preference {
  margin-top: 18rpx;
  display: inline-flex;
  padding: 14rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #92602b;
  font-size: 22rpx;
  line-height: 1.5;
}

.feedback-banner {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 30rpx rgba(31, 47, 37, 0.08);
}

.feedback-banner text {
  display: block;
  font-size: 24rpx;
  line-height: 1.62;
}

.feedback-banner-success {
  background: linear-gradient(135deg, #e9f7ef, #f8fcfa);
  color: #27563f;
}

.feedback-banner-info {
  background: linear-gradient(135deg, #eef4ff, #fbfcff);
  color: #3558a3;
}

.state-card,
.recipe-card,
.action-grid {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 40rpx rgba(31, 47, 37, 0.08);
}

.state-card {
  padding: 60rpx 38rpx;
  text-align: center;
}

.state-card.error {
  background: rgba(255, 248, 247, 0.96);
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  margin: 0 auto 20rpx;
  border: 4rpx solid rgba(34, 64, 51, 0.12);
  border-top-color: #355f4e;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.state-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #24342b;
}

.state-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #768079;
}

.state-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-top: 28rpx;
}

.solid-btn,
.outline-btn {
  min-width: 180rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.solid-btn {
  background: linear-gradient(135deg, #355f4e, #1f342a);
  color: #ffffff;
}

.outline-btn {
  border: 2rpx solid rgba(53, 95, 78, 0.16);
  color: #355f4e;
}

.version-switch {
  display: flex;
  padding: 8rpx;
  margin-bottom: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.85);
}

.version-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 20rpx;
  color: #6a766f;
  font-size: 26rpx;
}

.version-tab.active {
  background: #274539;
  color: #ffffff;
  font-weight: 600;
}

.recipe-card {
  overflow: hidden;
}

.recipe-cover {
  width: 100%;
  height: 420rpx;
  background: #e8ece9;
}

.recipe-body {
  padding: 30rpx 28rpx 32rpx;
}

.recipe-head {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.recipe-title-wrap {
  flex: 1;
}

.recipe-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #22342b;
}

.recipe-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8b6130;
}

.favorite-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #fff3eb;
  color: #b85b34;
  font-size: 22rpx;
}

.favorite-chip.active {
  background: linear-gradient(135deg, #e86d3f, #c95433);
  color: #ffffff;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #355f4e;
  font-size: 22rpx;
}

.meta-tag.warm {
  background: #fff3e7;
  color: #b86827;
}

.recipe-desc {
  display: block;
  margin-top: 22rpx;
  font-size: 26rpx;
  line-height: 1.78;
  color: #58645c;
}

.reason-card {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fcf4e8, #f9efe3);
}

.reason-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #8a5c2d;
}

.reason-item {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  color: #78542e;
  font-size: 24rpx;
  line-height: 1.6;
}

.reason-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #d48f44;
  flex-shrink: 0;
}

.reason-foot {
  display: block;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(120, 84, 46, 0.12);
  font-size: 22rpx;
  line-height: 1.6;
  color: #9a6b39;
}

.action-grid {
  margin-top: 22rpx;
  padding: 20rpx;
}

.primary-action {
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #234033, #345846);
  color: #ffffff;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.action-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.76);
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  border: none;
  text-align: left;
  box-sizing: border-box;
}

.action-card::after {
  border: none;
}

.action-card.fresh {
  background: #edf6ef;
}

.action-card.share {
  background: #fff4e9;
}

.action-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #24342b;
}

.action-card-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6a756e;
}


.member-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(34, 48, 41, 0.08);
}

.member-strip.active {
  background: linear-gradient(135deg, #fff7e8, #fff2dc);
}

.member-strip-main {
  flex: 1;
  min-width: 0;
}

.member-strip-title {
  display: block;
  color: #24342d;
  font-size: 28rpx;
  font-weight: 700;
}

.member-strip-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6f7f77;
  font-size: 22rpx;
  line-height: 1.6;
}

.member-strip-action {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #234033;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.quota-strip {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.quota-pill {
  min-width: 180rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f5f8ff, #eef3ff);
  box-shadow: 0 12rpx 24rpx rgba(48, 83, 144, 0.08);
  box-sizing: border-box;
}

.quota-pill-value {
  display: block;
  color: #365e9d;
  font-size: 28rpx;
  font-weight: 700;
}

.quota-pill-title {
  display: block;
  margin-top: 8rpx;
  color: #6a7792;
  font-size: 21rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.shortcut-card {
  padding: 22rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 30rpx rgba(34, 48, 41, 0.08);
}

.shortcut-card.warm {
  background: linear-gradient(135deg, #fff8ef, #fff1df);
}

.shortcut-card.light {
  background: linear-gradient(135deg, #f3f9f6, #eef8f1);
}

.shortcut-title {
  display: block;
  color: #24342d;
  font-size: 25rpx;
  font-weight: 700;
}

.shortcut-desc {
  display: block;
  margin-top: 10rpx;
  color: #74827b;
  font-size: 21rpx;
  line-height: 1.6;
}
