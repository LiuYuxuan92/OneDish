.container {
  min-height: 100vh;
  background: #f5f7fb;
}

/* Header Bar */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f5f7fb;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #999;
}

.profile-btn {
  font-size: 36rpx;
  padding: 8rpx;
}

/* 加载态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
  color: #999;
  font-size: 28rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 错误态 */
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 300rpx;
}

.error-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.error-text {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.btn-retry {
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 空态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-go {
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 正常内容 */
.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

/* 版本切换 Tab */
.version-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.version-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f7fb;
}

.version-tabs .tab.active {
  background: #1677ff;
  color: #fff;
  font-weight: 600;
}

.cover {
  width: 100%;
  height: 400rpx;
  background: #e5e7eb;
}

.info {
  padding: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 16rpx;
}

.version-badge {
  font-size: 22rpx;
  color: #07c160;
  background: #e6f7f0;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: normal;
}

.tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  background: #edf3ff;
  color: #1677ff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.baby-version {
  background: #fef3e2;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.baby-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f5a623;
  margin-bottom: 12rpx;
}

.baby-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.baby-info {
  background: #fef3e2;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.baby-age, .baby-tips {
  font-size: 26rpx;
  color: #f5a623;
  margin-bottom: 8rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.btn-swap, .btn-favorite {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-swap {
  background: #1677ff;
  color: #fff;
}

.btn-favorite {
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
}

.btn-add-list {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  color: #fff;
}

.share {
  display: flex;
  justify-content: center;
}

.btn-share {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 80rpx;
  font-size: 28rpx;
}
