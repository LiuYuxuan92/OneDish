.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1677ff 0%, #f5f7fb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.logo-emoji {
  font-size: 140rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-area, .user-area {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-wechat:active {
  opacity: 0.9;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider .line {
  flex: 1;
  height: 1rpx;
  background: #e5e7eb;
}

.divider .text {
  padding: 0 24rpx;
  color: #999;
  font-size: 24rpx;
}

.btn-guest {
  width: 100%;
  height: 88rpx;
  background: #f5f7fb;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 1rpx solid #e5e7eb;
}

.tips {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height:;
}

.user-area 1.6 {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #e5e7eb;
  margin-bottom: 24rpx;
}

.avatar-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
}

.role {
  font-size: 26rpx;
  color: #07c160;
  margin-bottom: 40rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #999;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 1rpx solid #e5e7eb;
}
