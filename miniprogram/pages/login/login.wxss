.page-shell {
  min-height: 100vh;
  padding: 80rpx 40rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top, rgba(225, 211, 190, 0.56), transparent 34%),
    linear-gradient(180deg, #f8f5ef 0%, #f2f4ef 46%, #eef2ee 100%);
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo-badge {
  width: 144rpx;
  height: 144rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(34, 52, 43, 0.1);
}

.app-name {
  margin-top: 26rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #22342b;
}

.slogan {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #748179;
  text-align: center;
}

.login-panel,
.user-panel {
  width: 100%;
  padding: 42rpx 34rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 22rpx 48rpx rgba(34, 52, 43, 0.08);
}

.panel-copy {
  margin-bottom: 30rpx;
}

.panel-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(39, 69, 57, 0.08);
  color: #55665e;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.panel-title {
  display: block;
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #22342b;
}

.panel-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #748179;
}

.benefit-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.benefit-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #486154;
  font-size: 22rpx;
}

.path-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 26rpx;
}

.path-card {
  flex: 1;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #edf4ef, #f7fbf7);
}

.path-card.soft {
  background: linear-gradient(135deg, #faf2e8, #fff9f2);
}

.path-title {
  display: block;
  color: #22342b;
  font-size: 24rpx;
  font-weight: 700;
}

.path-desc {
  display: block;
  margin-top: 10rpx;
  color: #748179;
  font-size: 21rpx;
  line-height: 1.6;
}

.btn-wechat,
.btn-guest,
.btn-logout {
  width: 100%;
  height: 92rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-wechat {
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
}

.btn-guest,
.btn-logout {
  background: #f3f4ef;
  color: #55665e;
  border: 1rpx solid rgba(39, 69, 57, 0.1);
}

.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider .line {
  flex: 1;
  height: 1rpx;
  background: rgba(84, 101, 93, 0.14);
}

.divider .text {
  padding: 0 22rpx;
  color: #91a097;
  font-size: 22rpx;
}

.tips,
.status-note {
  margin-top: 26rpx;
  font-size: 23rpx;
  line-height: 1.72;
  color: #7a847d;
  text-align: center;
}

.user-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-shell {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f7f3ec, #edf2ee);
  box-shadow: inset 0 0 0 2rpx rgba(39, 69, 57, 0.08);
}

.username {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #22342b;
}

.role {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #3d6956;
}
