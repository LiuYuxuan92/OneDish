.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(223, 215, 201, 0.42), transparent 34%),
    linear-gradient(180deg, #f8f5ef 0%, #f2f4ef 42%, #eef2ee 100%);
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #7b857f;
  font-size: 24rpx;
}

.spinner {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 14rpx;
  border: 4rpx solid rgba(39, 69, 57, 0.1);
  border-top-color: #274539;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.favorite-item {
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 38rpx rgba(34, 52, 43, 0.08);
}

.item-content {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
}

.item-cover {
  width: 180rpx;
  height: 132rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #edece6, #e3e8e3);
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #22342b;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.item-meta text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f4ef;
  color: #71807a;
  font-size: 22rpx;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 22rpx 20rpx;
  border-top: 1rpx solid rgba(34, 52, 43, 0.06);
}

.btn-remove {
  font-size: 24rpx;
  color: #a86954;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 180rpx 36rpx 0;
  text-align: center;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(34, 52, 43, 0.08);
}

.empty-text {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #22342b;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #7a847d;
}

.btn-go {
  margin-top: 30rpx;
  padding: 22rpx 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-go::after {
  border: none;
}
