.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(227, 216, 198, 0.42), transparent 34%),
    radial-gradient(circle at top right, rgba(205, 225, 213, 0.18), transparent 26%),
    linear-gradient(180deg, #faf4ec 0%, #f2f4ef 42%, #eef2ee 100%);
}

.favorites-hero {
  padding: 30rpx 30rpx 32rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 224, 188, 0.84), transparent 34%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(252, 248, 242, 0.98));
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 18rpx 38rpx rgba(34, 52, 43, 0.08);
}

.favorites-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf3ef;
  color: #6d7a73;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.favorites-title {
  display: block;
  margin-top: 18rpx;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #22342b;
}

.favorites-desc {
  display: block;
  margin-top: 14rpx;
  color: #728078;
  font-size: 24rpx;
  line-height: 1.7;
}

.favorites-meta-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.favorites-meta-card {
  flex: 1;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
}

.favorites-meta-card.soft {
  background: rgba(247, 239, 226, 0.78);
}

.favorites-meta-value {
  display: block;
  color: #22342b;
  font-size: 28rpx;
  font-weight: 700;
}

.favorites-meta-label {
  display: block;
  margin-top: 8rpx;
  color: #7a847d;
  font-size: 20rpx;
}

.favorites-hero-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.favorites-hero-btn {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.favorites-hero-btn.primary {
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
  font-weight: 700;
}

.favorites-hero-btn.secondary {
  background: rgba(255, 255, 255, 0.78);
  color: #6f7b75;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #7b857f;
  font-size: 24rpx;
}

.spinner {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 14rpx;
  border: 4rpx solid rgba(39, 69, 57, 0.1);
  border-top-color: #274539;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.favorite-item {
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(39, 69, 57, 0.05);
  box-shadow: 0 18rpx 38rpx rgba(34, 52, 43, 0.08);
}

.item-content {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 22rpx 20rpx;
}

.item-cover {
  width: 156rpx;
  height: 120rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #edece6, #e3e8e3);
  flex-shrink: 0;
}

.item-cover-fallback {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 18rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 224, 188, 0.76), transparent 34%),
    linear-gradient(135deg, #f2f4f8, #e8efe9);
}

.item-cover-kicker {
  color: #74818d;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.item-cover-copy {
  display: block;
  margin-top: 10rpx;
  color: #23342b;
  font-size: 24rpx;
  font-weight: 700;
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-source-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.item-source-tag {
  display: inline-flex;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 700;
}

.item-source-tag.cloud {
  background: #edf5ee;
  color: #2e5a49;
}

.item-source-tag.local {
  background: #f6efe3;
  color: #8c663c;
}

.item-link {
  color: #8b6a43;
  font-size: 21rpx;
}

.item-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #22342b;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.item-meta text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f4ef;
  color: #71807a;
  font-size: 22rpx;
}

.item-note {
  display: block;
  margin-top: 12rpx;
  color: #76827b;
  font-size: 21rpx;
  line-height: 1.6;
}

.item-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 22rpx 20rpx;
  border-top: 1rpx solid rgba(34, 52, 43, 0.06);
  background: rgba(248, 249, 246, 0.72);
}

.item-actions-main {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  flex: 1;
}

.btn-open {
  display: inline-flex;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #edf3ef;
  color: #274539;
  font-size: 22rpx;
  font-weight: 700;
}

.btn-secondary {
  display: inline-flex;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #5c6f65;
  font-size: 22rpx;
}

.btn-remove {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #a86954;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 180rpx 36rpx 0;
  text-align: center;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(34, 52, 43, 0.08);
}

.empty-text {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #22342b;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #7a847d;
}

.btn-go {
  margin-top: 30rpx;
  padding: 22rpx 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-go::after {
  border: none;
}
