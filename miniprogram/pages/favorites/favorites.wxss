.container {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx;
  color: #999;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* List */
.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.favorite-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.item-content {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
}

.item-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f7fb;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.item-meta {
  display: flex;
  gap: 12rpx;
}

.item-meta text {
  font-size: 24rpx;
  color: #999;
  background: #f5f7fb;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  padding: 12rpx 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.btn-remove {
  font-size: 26rpx;
  color: #ff4d4f;
}

/* Empty */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-go {
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}
