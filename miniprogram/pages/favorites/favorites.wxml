<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 收藏列表 -->
  <view class="favorites-list" wx:else>
    <block wx:for="{{favorites.length ? favorites : localFavorites}}" wx:key="id">
      <view class="favorite-item">
        <view class="item-content" bindtap="goToRecipe" data-id="{{item.id}}">
          <image 
            class="item-cover" 
            src="{{item.cover_url || '/assets/placeholder-food.png'}}" 
            mode="aspectFill"
          />
          <view class="item-info">
            <view class="item-title">{{item.title || item.name}}</view>
            <view class="item-meta">
              <text wx:if="{{item.difficulty}}">{{item.difficulty}}</text>
              <text wx:if="{{item.cook_time}}">{{item.cook_time}}分钟</text>
            </view>
          </view>
        </view>
        <view class="item-actions">
          <text class="btn-remove" bindtap="removeFavorite" data-id="{{item.id}}">取消收藏</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !favorites.length && !localFavorites.length}}">
    <image class="empty-icon" src="/assets/empty.png" mode="aspectFit" />
    <text class="empty-text">暂无收藏</text>
    <text class="empty-hint">去发现喜欢的菜谱吧</text>
    <button class="btn-go" bindtap="goToRecipeList">浏览菜谱</button>
  </view>
</view>
