.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(224, 215, 199, 0.42), transparent 34%),
    linear-gradient(180deg, #f8f5ef 0%, #f1f4ef 42%, #eef2ee 100%);
}

.contact-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  line-height: inherit;
}

.contact-btn::after {
  border: none;
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 24rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #274539, #3b5c4d);
  box-shadow: 0 22rpx 44rpx rgba(34, 52, 43, 0.14);
}

.hero-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 1.6;
}

.hero-action {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-group {
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 38rpx rgba(34, 52, 43, 0.08);
}

.cell-title {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  color: #24342b;
  font-size: 28rpx;
}

.picker-mask,
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(22, 31, 26, 0.42);
  z-index: 100;
}

.picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 60vh;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  z-index: 101;
}

.picker-header,
.ai-config-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(36, 52, 43, 0.06);
}

.picker-cancel,
.ai-config-close {
  color: #7e8983;
  font-size: 30rpx;
}

.picker-title,
.ai-config-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #22342b;
}

.picker-done {
  width: 100rpx;
}

.picker-list {
  max-height: 50vh;
}

.picker-item {
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #24342b;
}

.picker-item.active {
  color: #274539;
  font-weight: 700;
}

.ai-config-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 650rpx;
  max-height: 75vh;
  overflow: hidden;
  border-radius: 30rpx;
  background: #ffffff;
  z-index: 201;
  box-shadow: 0 24rpx 54rpx rgba(26, 37, 31, 0.18);
}

.ai-config-body {
  max-height: 55vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.config-group {
  margin-bottom: 32rpx;
}

.config-label {
  display: block;
  margin-bottom: 14rpx;
  color: #24342b;
  font-size: 28rpx;
  font-weight: 700;
}

.config-input {
  width: 100%;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #f3f5f1;
  border: 1rpx solid rgba(39, 69, 57, 0.08);
  font-size: 27rpx;
  color: #24342b;
}

.config-age-options,
.config-time-options,
.config-difficulty-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.config-age-option,
.config-time-option,
.config-difficulty-option {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f5f1;
  border: 1rpx solid rgba(39, 69, 57, 0.08);
  font-size: 24rpx;
  color: #66736c;
}

.config-age-option.active,
.config-time-option.active,
.config-difficulty-option.active {
  background: #e7efe9;
  border-color: rgba(39, 69, 57, 0.18);
  color: #274539;
}

.ai-config-footer {
  padding: 24rpx;
  border-top: 1rpx solid rgba(36, 52, 43, 0.06);
}

.config-save-btn {
  width: 100%;
  padding: 24rpx 0;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}
