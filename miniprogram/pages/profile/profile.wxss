.container {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
}

.member-cell {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin-bottom: 24rpx;
  border-radius: 16rpx;
}

.member-slot {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-icon {
  font-size: 48rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.member-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.tips {
  font-size: 24rpx;
  color: #969799;
  padding: 16rpx 32rpx 24rpx;
  line-height: 1.5;
}

/* Picker */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.picker-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 60vh;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel {
  color: #969799;
  font-size: 30rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.picker-done {
  width: 100rpx;
}

.picker-list {
  max-height: 50vh;
}

.picker-item {
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #323233;
}

.picker-item.active {
  color: #1677ff;
  font-weight: 600;
}
