<view class="container">
  <van-cell-group>
  <!-- 会员入口 -->
  <van-cell is-link bindtap="goToMembership" custom-class="member-cell">
    <view slot="title" class="member-slot">
      <text class="member-icon">👑</text>
      <view class="member-info">
        <view class="member-title">开通会员</view>
        <view class="member-desc">AI推荐 + 专属菜谱 + 无广告</view>
      </view>
    </view>
  </van-cell>

  <!-- 宝宝月龄 -->
  <van-cell title="宝宝月龄" value="{{babyAgeText}}" is-link bindtap="showAgePicker"/>
  
  <!-- 账号 -->
  <van-cell title="账号" is-link bindtap="goToLogin"/>
  
  <!-- 版本 -->
  <van-cell title="版本">
    <van-tag type="success">1.0.0</van-tag>
  </van-cell>
</van-cell-group>

  <!-- 月龄选择器 -->
  <view class="picker-mask" wx:if="{{showPicker}}" bindtap="hidePicker"></view>
  <view class="picker-panel" wx:if="{{showPicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hidePicker">取消</text>
      <text class="picker-title">选择宝宝月龄</text>
      <text class="picker-done"></text>
    </view>
    <scroll-view class="picker-list" scroll-y>
      <view 
        class="picker-item {{babyAge === item.value ? 'active' : ''}}"
        wx:for="{{ageOptions}}"
        wx:key="value"
        bindtap="onAgeSelect"
        data-age="{{item.value}}">
        {{item.label}}
      </view>
    </scroll-view>
  </view>
</view>
