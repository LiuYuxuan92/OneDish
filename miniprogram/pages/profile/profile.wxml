<view class="page-shell">
  <view class="hero-card" bindtap="goToMembership">
    <view class="hero-icon">
      <van-icon name="award-o" size="24" color="#ffffff" />
    </view>
    <view class="hero-copy">
      <view class="hero-title">成长会员</view>
      <view class="hero-desc">AI 推荐、专属菜谱与跨端权益同步</view>
    </view>
    <view class="hero-action">查看</view>
  </view>

  <view class="profile-summary">
    <text class="summary-kicker">CARE PROFILE</text>
    <text class="summary-title">把宝宝月龄和下厨偏好先设好</text>
    <text class="summary-desc">后续推荐、搜索和周计划都会优先按这里的设置工作。</text>
    <view class="summary-grid">
      <view class="summary-stat">
        <text class="summary-value">{{babyAgeText || '未设置'}}</text>
        <text class="summary-label">宝宝月龄</text>
      </view>
      <view class="summary-stat">
        <text class="summary-value">{{aiConfig.cooking_time_limit}} 分钟</text>
        <text class="summary-label">下厨时长</text>
      </view>
      <view class="summary-stat">
        <text class="summary-value">{{aiConfig.difficulty_preference === 'easy' ? '简单' : aiConfig.difficulty_preference === 'hard' ? '进阶' : '适中'}}</text>
        <text class="summary-label">难度偏好</text>
      </view>
    </view>
    <view class="summary-tags">
      <text class="summary-tag warm">{{aiConfig.prefer_ingredients ? ('偏好 ' + aiConfig.prefer_ingredients) : '偏好食材未设置'}}</text>
      <text class="summary-tag">{{aiConfig.exclude_ingredients ? ('避开 ' + aiConfig.exclude_ingredients) : '忌口未设置'}}</text>
    </view>
  </view>

  <view class="profile-hub">
    <view class="section-heading">
      <text class="section-title">今天继续</text>
      <text class="section-desc">从常用入口开始，做饭更顺手。</text>
    </view>
    <view class="hub-grid">
      <view class="hub-card primary" bindtap="goToPlan">
        <view class="hub-icon">
          <van-icon name="orders-o" size="18" color="#274539" />
        </view>
        <text class="hub-title">本周计划</text>
        <text class="hub-desc">继续看清单和备餐安排</text>
        <text class="hub-meta">从今天要做的开始</text>
      </view>

      <view class="hub-card warm" bindtap="goToFavorites">
        <view class="hub-icon warm">
          <van-icon name="star-o" size="18" color="#8a6030" />
        </view>
        <text class="hub-title">我的收藏</text>
        <text class="hub-desc">常做菜谱集中放这里</text>
        <text class="hub-meta">{{favoritesCount ? (favoritesCount + ' 道本地收藏') : '进入查看已收菜谱'}}</text>
      </view>

      <view class="hub-card" bindtap="openAIConfigModal">
        <view class="hub-icon soft">
          <van-icon name="setting-o" size="18" color="#486154" />
        </view>
        <text class="hub-title">AI 偏好</text>
        <text class="hub-desc">月龄、时长和口味限制</text>
        <text class="hub-meta">{{babyAgeText || '先设置宝宝月龄'}}</text>
      </view>

      <view class="hub-card soft-card" bindtap="goToFamily">
        <view class="hub-icon soft">
          <van-icon name="friends-o" size="18" color="#486154" />
        </view>
        <text class="hub-title">家庭入口</text>
        <text class="hub-desc">查看家庭功能规划与占位说明</text>
        <text class="hub-meta">创建、加入、邀请码和成员能力仍在建设中</text>
      </view>

      <view class="hub-card" bindtap="goToLogin">
        <view class="hub-icon soft">
          <van-icon name="contact-o" size="18" color="#486154" />
        </view>
        <text class="hub-title">账号与同步</text>
        <text class="hub-desc">登录后可同步偏好与收藏</text>
        <text class="hub-meta">{{hasToken ? '已登录，可跨端同步' : '未登录，本地模式'}}</text>
      </view>
    </view>
  </view>

  <view class="section-heading section-heading-tight">
    <text class="section-title">设置与支持</text>
    <text class="section-desc">基础设置、客服和版本信息。</text>
  </view>

  <van-cell-group custom-class="profile-group">
    <van-cell is-link bindtap="showAgePicker">
      <view slot="title" class="cell-title">
        <van-icon name="calendar-o" size="18" color="#486154" />
        <text>宝宝月龄</text>
      </view>
      <text>{{babyAgeText}}</text>
    </van-cell>

    <van-cell is-link bindtap="openAIConfigModal">
      <view slot="title" class="cell-title">
        <van-icon name="setting-o" size="18" color="#486154" />
        <text>AI 偏好</text>
      </view>
      <text>自定义</text>
    </van-cell>

    <van-cell is-link bindtap="goToPlan">
      <view slot="title" class="cell-title">
        <van-icon name="orders-o" size="18" color="#486154" />
        <text>本周计划</text>
      </view>
      <text>查看计划与清单</text>
    </van-cell>

    <van-cell is-link bindtap="goToFavorites">
      <view slot="title" class="cell-title">
        <van-icon name="star-o" size="18" color="#486154" />
        <text>我的收藏</text>
      </view>
      <text>查看常做菜谱</text>
    </van-cell>

    <van-cell is-link bindtap="goToFamily">
      <view slot="title" class="cell-title">
        <van-icon name="friends-o" size="18" color="#486154" />
        <text>家庭入口</text>
      </view>
      <text>查看占位页与能力建设说明</text>
    </van-cell>

    <button class="contact-btn" open-type="contact">
      <van-cell is-link>
        <view slot="title" class="cell-title">
          <van-icon name="service-o" size="18" color="#486154" />
          <text>联系客服</text>
        </view>
      </van-cell>
    </button>

    <van-cell is-link bindtap="goToLogin">
      <view slot="title" class="cell-title">
        <van-icon name="contact-o" size="18" color="#486154" />
        <text>账号</text>
      </view>
    </van-cell>

    <van-cell>
      <view slot="title" class="cell-title">
        <van-icon name="label-o" size="18" color="#486154" />
        <text>版本</text>
      </view>
      <van-tag color="#eef3ef" text-color="#486154">1.0.0</van-tag>
    </van-cell>
  </van-cell-group>

  <view class="picker-mask" wx:if="{{showPicker}}" bindtap="hidePicker"></view>
  <view class="picker-panel" wx:if="{{showPicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hidePicker">取消</text>
      <text class="picker-title">选择宝宝月龄</text>
      <text class="picker-done"></text>
    </view>
    <scroll-view class="picker-list" scroll-y>
      <view
        class="picker-item {{babyAge === item.value ? 'active' : ''}}"
        wx:for="{{ageOptions}}"
        wx:key="value"
        bindtap="onAgeSelect"
        data-age="{{item.value}}">
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <view class="modal-mask" wx:if="{{showAIConfigModal}}" bindtap="closeAIConfigModal"></view>
  <view class="ai-config-modal" wx:if="{{showAIConfigModal}}">
    <view class="ai-config-header">
      <text class="ai-config-title">AI 偏好</text>
      <text class="ai-config-close" bindtap="closeAIConfigModal">×</text>
    </view>
    <scroll-view class="ai-config-body" scroll-y>
      <view class="config-group">
        <text class="config-label">默认宝宝月龄</text>
        <view class="config-age-options">
          <view class="config-age-option {{aiConfig.default_baby_age === 6 ? 'active' : ''}}" data-field="default_baby_age" data-value="6" bindtap="onAIConfigInput">6 月</view>
          <view class="config-age-option {{aiConfig.default_baby_age === 8 ? 'active' : ''}}" data-field="default_baby_age" data-value="8" bindtap="onAIConfigInput">8 月</view>
          <view class="config-age-option {{aiConfig.default_baby_age === 10 ? 'active' : ''}}" data-field="default_baby_age" data-value="10" bindtap="onAIConfigInput">10 月</view>
          <view class="config-age-option {{aiConfig.default_baby_age === 12 ? 'active' : ''}}" data-field="default_baby_age" data-value="12" bindtap="onAIConfigInput">12 月</view>
          <view class="config-age-option {{aiConfig.default_baby_age === 18 ? 'active' : ''}}" data-field="default_baby_age" data-value="18" bindtap="onAIConfigInput">18 月</view>
          <view class="config-age-option {{aiConfig.default_baby_age === 24 ? 'active' : ''}}" data-field="default_baby_age" data-value="24" bindtap="onAIConfigInput">24 月</view>
        </view>
      </view>

      <view class="config-group">
        <text class="config-label">偏好食材（用逗号分隔）</text>
        <input
          class="config-input"
          placeholder="例如：鱼肉、鸡肉、胡萝卜"
          value="{{aiConfig.prefer_ingredients}}"
          data-field="prefer_ingredients"
          bindinput="onAIConfigInput"
        />
      </view>

      <view class="config-group">
        <text class="config-label">排除食材（用逗号分隔）</text>
        <input
          class="config-input"
          placeholder="例如：虾、花生、牛奶"
          value="{{aiConfig.exclude_ingredients}}"
          data-field="exclude_ingredients"
          bindinput="onAIConfigInput"
        />
      </view>

      <view class="config-group">
        <text class="config-label">烹饪时间限制（分钟）</text>
        <view class="config-time-options">
          <view class="config-time-option {{aiConfig.cooking_time_limit === 15 ? 'active' : ''}}" data-field="cooking_time_limit" data-value="15" bindtap="onAIConfigInput">15 分钟</view>
          <view class="config-time-option {{aiConfig.cooking_time_limit === 30 ? 'active' : ''}}" data-field="cooking_time_limit" data-value="30" bindtap="onAIConfigInput">30 分钟</view>
          <view class="config-time-option {{aiConfig.cooking_time_limit === 45 ? 'active' : ''}}" data-field="cooking_time_limit" data-value="45" bindtap="onAIConfigInput">45 分钟</view>
          <view class="config-time-option {{aiConfig.cooking_time_limit === 60 ? 'active' : ''}}" data-field="cooking_time_limit" data-value="60" bindtap="onAIConfigInput">60 分钟</view>
        </view>
      </view>

      <view class="config-group">
        <text class="config-label">难度偏好</text>
        <view class="config-difficulty-options">
          <view class="config-difficulty-option {{aiConfig.difficulty_preference === 'easy' ? 'active' : ''}}" data-difficulty="easy" bindtap="onDifficultySelect">简单</view>
          <view class="config-difficulty-option {{aiConfig.difficulty_preference === 'medium' ? 'active' : ''}}" data-difficulty="medium" bindtap="onDifficultySelect">适中</view>
          <view class="config-difficulty-option {{aiConfig.difficulty_preference === 'hard' ? 'active' : ''}}" data-difficulty="hard" bindtap="onDifficultySelect">进阶</view>
        </view>
      </view>
    </scroll-view>
    <view class="ai-config-footer">
      <button class="config-save-btn" bindtap="saveAIConfig" loading="{{isSavingAI}}">
        {{isSavingAI ? '保存中...' : '保存设置'}}
      </button>
    </view>
  </view>
</view>
