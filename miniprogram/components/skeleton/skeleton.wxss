.skeleton {
  width: 100%;
}

/* List Skeleton */
.skeleton-list {
  padding: 24rpx;
}

.skeleton-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-img {
  width: 160rpx;
  height: 120rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-title {
  height: 32rpx;
  width: 70%;
  background: #f0f0f0;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-desc {
  height: 24rpx;
  width: 50%;
  background: #f0f0f0;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

/* Detail Skeleton */
.skeleton-detail {
  padding: 0;
}

.skeleton-cover {
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
  animation: shimmer 1.5s infinite;
}

.skeleton-info {
  padding: 24rpx;
}

.skeleton-title-lg {
  height: 48rpx;
  width: 80%;
  background: #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.skeleton-tag {
  height: 36rpx;
  width: 100rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-text {
  height: 28rpx;
  width: 100%;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-text.short {
  width: 60%;
}

/* Card Skeleton */
.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 24rpx;
}

.skeleton-card-cover {
  width: 100%;
  height: 300rpx;
  background: #f0f0f0;
  animation: shimmer 1.5s infinite;
}

.skeleton-card-info {
  padding: 24rpx;
}

.skeleton-card-title {
  height: 36rpx;
  width: 60%;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-card-desc {
  height: 24rpx;
  width: 90%;
  background: #f0f0f0;
  border-radius: 8rpx;
  animation: shimmer 1.5s infinite;
}

/* Shimmer Animation */
@keyframes shimmer {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
  100% {
    opacity: 1;
  }
}
