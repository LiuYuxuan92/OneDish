.poster-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(18, 27, 22, 0.56);
}

.poster-content {
  position: relative;
  width: 650rpx;
  padding: 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #fcfaf6 0%, #f3f5f0 100%);
  box-shadow: 0 26rpx 56rpx rgba(18, 27, 22, 0.18);
}

.poster-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #22342b;
  margin-bottom: 24rpx;
}

.canvas-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.poster-canvas,
.poster-preview {
  width: 300px;
  height: 450px;
  display: block;
  border-radius: 26rpx;
  background: #f2f4ef;
}

.poster-preview {
  margin: 0 auto 24rpx;
}

.poster-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-group {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.btn::after {
  border: none;
}

.btn-generate,
.btn-share {
  background: linear-gradient(135deg, #274539, #325849);
  color: #ffffff;
}

.btn-save {
  background: linear-gradient(135deg, #8d6a40, #b58b5c);
  color: #ffffff;
}

.close-btn {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.86);
}
